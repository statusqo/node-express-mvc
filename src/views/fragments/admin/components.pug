//- Admin shared component mixins.
//- Included once from layouts/admin.pug — available on every admin page without explicit include.

//- ── +pageHeader(title, subtitle) ────────────────────────────────────────────
//- Page title block. Pass a block for right-side content (+backBtn or +addBtn).
mixin pageHeader(title, subtitle)
    .da-page-header
        .da-page-header-left
            h1.da-page-title= title
            if subtitle
                p.da-page-subtitle= subtitle
        .da-page-header-right
            block

//- ── +backBtn(url, label) ─────────────────────────────────────────────────────
//- Secondary back button with left-chevron icon.
mixin backBtn(url, label)
    a.da-btn.da-btn--secondary(href=url)
        svg(xmlns='http://www.w3.org/2000/svg' width='13' height='13' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
            polyline(points='15 18 9 12 15 6')
        | #{label}

//- ── +addBtn(url, label) ──────────────────────────────────────────────────────
//- Primary add/create button with plus icon.
mixin addBtn(url, label)
    a.da-btn.da-btn--primary(href=url)
        svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
            line(x1='12' y1='5' x2='12' y2='19')
            line(x1='5' y1='12' x2='19' y2='12')
        | #{label}

//- ── +inlineDelete(deleteUrl, itemLabel) ────────────────────────────────────
//- Inline delete trigger with animated confirm group. Driven by admin-delete-flow.js.
mixin inlineDelete(deleteUrl, itemLabel)
    .da-delete-wrap(aria-label='Delete ' + (itemLabel || 'item') + ' actions')
        button.da-row-btn.da-row-btn--delete.da-delete-trigger(
            type='button'
            aria-label='Delete ' + (itemLabel || 'item')
            aria-expanded='false'
        ) Delete
        .da-confirm-group(role='group' aria-label='Confirm deletion')
            button.da-row-btn.da-row-btn--cancel.da-delete-cancel(
                type='button'
                aria-label='Cancel deletion'
            ) No
            span.da-confirm-sep(aria-hidden='true')
            form.da-form-inline.da-delete-form(method='post' action=deleteUrl)
                button.da-row-btn.da-row-btn--confirm(
                    type='submit'
                    aria-label='Confirm delete ' + (itemLabel || 'item')
                ) Yes, delete

//- ── +tableEmpty(message, colspan) ──────────────────────────────────────────
//- Empty-state row for use inside a <tbody>.
mixin tableEmpty(message, colspan)
    tr
        td(colspan=colspan || 5)
            .da-table-empty= message

//- ── +readonlyField(label) ───────────────────────────────────────────────────
//- Read-only label/value pair. Put the value content in the block.
mixin readonlyField(label)
    .da-readonly-group
        span.da-readonly-label= label
        .da-readonly-value
            block

//- ── +formError(error) ───────────────────────────────────────────────────────
//- Inline validation error shown above a form. Renders nothing when error is falsy.
mixin formError(error)
    if error
        p.admin-flash.admin-flash-error= error

//- ── +eventSummaryCard(event, registrantCount) ───────────────────────────────
//- Horizontal summary strip for an event. Displays date, time, product, type,
//- status, location, capacity and registrant count in a single card row.
//- @param {object} event           - Plain event object (startDate, startTime, isOnline, etc.)
//- @param {number} registrantCount - Number of registrants to display
mixin eventSummaryCard(event, registrantCount)
    - var _dp = event.startDate ? String(event.startDate).substring(0,10).split('-') : null
    - var _date = _dp && _dp.length === 3 ? _dp[2] + '/' + _dp[1] + '/' + _dp[0] : '—'
    - var _time = event.startTime ? String(event.startTime).substring(0,5) : '—'
    - var _product = event.Product ? event.Product.title : '—'
    - var _type = event.Product && event.Product.ProductType ? event.Product.ProductType.name : '—'
    - var _statusClass = ({active:'success', cancelled:'danger', orphaned:'warning'})[event.eventStatus] || 'neutral'
    - var _statusLabel = event.eventStatus ? event.eventStatus.charAt(0).toUpperCase() + event.eventStatus.slice(1) : '—'
    .da-event-summary-scroll
      .da-event-summary
        .da-event-summary__item
            span.da-event-summary__label Date
            span.da-event-summary__value= _date
        .da-event-summary__item
            span.da-event-summary__label Time
            span.da-event-summary__value= _time
        .da-event-summary__item
            span.da-event-summary__label Product
            span.da-event-summary__value= _product
        .da-event-summary__item
            span.da-event-summary__label Type
            span.da-event-summary__value= _type
        .da-event-summary__item
            span.da-event-summary__label Status
            span.da-event-summary__value
                span.da-badge(class='da-badge--' + _statusClass)= _statusLabel
        .da-event-summary__item
            span.da-event-summary__label Location
            span.da-event-summary__value
                if event.isOnline
                    span.da-badge.da-badge--info Online
                else
                    = event.location || '—'
        if event.capacity != null
            .da-event-summary__item
                span.da-event-summary__label Capacity
                span.da-event-summary__value= event.capacity
        .da-event-summary__item
            span.da-event-summary__label Registrants
            span.da-event-summary__value= registrantCount != null ? registrantCount : 0
