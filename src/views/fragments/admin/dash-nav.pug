include ../shared/nav-menu-mixins

-
  function stripPostFromTree(nodes) {
    if (!nodes || !nodes.length) return []
    const out = []
    for (const n of nodes) {
      if (n.method === 'POST') continue
      const copy = { ...n }
      if (n.children && n.children.length) {
        const c = stripPostFromTree(n.children)
        if (c.length) copy.children = c
        else delete copy.children
      }
      out.push(copy)
    }
    return out
  }
  function collectPostItems(nodes, acc) {
    if (!nodes || !nodes.length) return
    for (const n of nodes) {
      if (n.method === 'POST') acc.push(n)
      if (n.children && n.children.length) collectPostItems(n.children, acc)
    }
  }

- const sidebarMenu = menus && menus['admin-sidebar'] ? menus['admin-sidebar'] : []
- const navTree = stripPostFromTree(sidebarMenu)
- const postItemsCollected = []
- collectPostItems(sidebarMenu, postItemsCollected)

div(class="dash-nav" data-admin-sidebar-nav)
    div(class="dash-brand")
        a(href=(adminPrefix || '') + "/") Admin Panel

    ul(class="dash-menu admin-nav-root" role="list")
        if navTree && navTree.length
            +navMenuBranch(navTree, adminPrefix, 0)
        else
            //- Minimal fallback if menu not seeded (flat + one nested Settings group)
            li.admin-nav-item
                a.admin-nav-link(href=(adminPrefix || '') + "/") Dashboard
            li.admin-nav-item
                a.admin-nav-link(href=(adminPrefix || '') + "/users") Users
            li.admin-nav-group(data-nav-group)
                .admin-nav-row
                    a.admin-nav-link.admin-nav-link--parent(href=(adminPrefix || '') + "/events") Events
                    button.admin-nav-toggle(type="button" aria-expanded="false" aria-label="Toggle Events submenu")
                        span.admin-nav-chevron(aria-hidden="true")
                ul.admin-nav-sublist(role="list")
                    li.admin-nav-item
                        a.admin-nav-link(href=(adminPrefix || '') + "/webinars") Webinars
                    li.admin-nav-item
                        a.admin-nav-link(href=(adminPrefix || '') + "/seminars") Seminars
                    li.admin-nav-item
                        a.admin-nav-link(href=(adminPrefix || '') + "/classrooms") Classrooms
            li.admin-nav-group(data-nav-group)
                .admin-nav-row
                    a.admin-nav-link.admin-nav-link--parent(href=(adminPrefix || '') + "/products") Products
                    button.admin-nav-toggle(type="button" aria-expanded="false" aria-label="Toggle Products submenu")
                        span.admin-nav-chevron(aria-hidden="true")
                ul.admin-nav-sublist(role="list")
                    li.admin-nav-item
                        a.admin-nav-link(href=(adminPrefix || '') + "/product-types") Product Types
                    li.admin-nav-item
                        a.admin-nav-link(href=(adminPrefix || '') + "/product-categories") Product Categories
                    li.admin-nav-item
                        a.admin-nav-link(href=(adminPrefix || '') + "/tax-rates") Tax Rates
                    li.admin-nav-item
                        a.admin-nav-link(href=(adminPrefix || '') + "/meta-objects") Meta Objects
            li.admin-nav-group(data-nav-group)
                .admin-nav-row
                    a.admin-nav-link.admin-nav-link--parent(href=(adminPrefix || '') + "/orders") Orders
                    button.admin-nav-toggle(type="button" aria-expanded="false" aria-label="Toggle Orders submenu")
                        span.admin-nav-chevron(aria-hidden="true")
                ul.admin-nav-sublist(role="list")
                    li.admin-nav-item
                        a.admin-nav-link(href=(adminPrefix || '') + "/refund-requests") Refund Requests
            li.admin-nav-item
                a.admin-nav-link(href=(adminPrefix || '') + "/collections") Collections
            li.admin-nav-item
                a.admin-nav-link(href=(adminPrefix || '') + "/media") Media
            li.admin-nav-item
                a.admin-nav-link(href=(adminPrefix || '') + "/blog") Blog
            li.admin-nav-group(data-nav-group)
                .admin-nav-row
                    a.admin-nav-link.admin-nav-link--parent(href=(adminPrefix || '') + "/menus") Menus
                    button.admin-nav-toggle(type="button" aria-expanded="false" aria-label="Toggle Menus submenu")
                        span.admin-nav-chevron(aria-hidden="true")
                ul.admin-nav-sublist(role="list")
                    li.admin-nav-item
                        a.admin-nav-link(href=(adminPrefix || '') + "/menu-items") Menu Items
            li.admin-nav-group(data-nav-group)
                .admin-nav-row
                    a.admin-nav-link.admin-nav-link--parent(href=(adminPrefix || '') + "/settings") Settings
                    button.admin-nav-toggle(type="button" aria-expanded="false" aria-label="Toggle Settings submenu")
                        span.admin-nav-chevron(aria-hidden="true")
                ul.admin-nav-sublist(role="list")
                    li.admin-nav-item
