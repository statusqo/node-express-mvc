include ../shared/nav-menu-mixins

-
  function stripPostFromTree(nodes) {
    if (!nodes || !nodes.length) return []
    const out = []
    for (const n of nodes) {
      if (n.method === 'POST') continue
      const copy = { ...n }
      if (n.children && n.children.length) {
        const c = stripPostFromTree(n.children)
        if (c.length) copy.children = c
        else delete copy.children
      }
      out.push(copy)
    }
    return out
  }
  function collectPostItems(nodes, acc) {
    if (!nodes || !nodes.length) return
    for (const n of nodes) {
      if (n.method === 'POST') acc.push(n)
      if (n.children && n.children.length) collectPostItems(n.children, acc)
    }
  }

- const sidebarMenu = menus && menus['admin-sidebar'] ? menus['admin-sidebar'] : []
- const navTree = stripPostFromTree(sidebarMenu)
- const postItemsCollected = []
- collectPostItems(sidebarMenu, postItemsCollected)

div(class="dash-nav" data-admin-sidebar-nav)
    div(class="dash-brand")
        a(href=(adminPrefix || '') + "/") Admin Panel

    ul(class="dash-menu admin-nav-root" role="list")
        if navTree && navTree.length
            +navMenuBranch(navTree, adminPrefix)
        else
            //- Minimal fallback if menu not seeded. Uses the same _sidebarLinkActive /
            //- _sidebarGroupHasActive helpers defined in nav-menu-mixins.pug so active
            //- state is also server-rendered correctly here.
            li.admin-nav-item
                a.admin-nav-link(
                    href=(adminPrefix || '') + "/"
                    class=(_sidebarLinkActive('/') ? 'is-active' : null)
                ) Dashboard
            li.admin-nav-item
                a.admin-nav-link(
                    href=(adminPrefix || '') + "/users"
                    class=(_sidebarLinkActive('/users') ? 'is-active' : null)
                ) Users
            -
              var _fbEventsOpen = _sidebarLinkActive('/events') || _sidebarLinkActive('/webinars') || _sidebarLinkActive('/seminars') || _sidebarLinkActive('/classrooms') || _sidebarGroupIsOpen('/events');
            li.admin-nav-group(data-nav-group class=(_fbEventsOpen ? 'is-open' : null))
                .admin-nav-row
                    a.admin-nav-link.admin-nav-link--parent(
                        href=(adminPrefix || '') + "/events"
                        class=(_sidebarLinkActive('/events') ? 'is-active' : null)
                    ) Events
                    button.admin-nav-toggle(type="button" aria-expanded=(_fbEventsOpen ? 'true' : 'false') aria-label="Toggle Events submenu")
                        span.admin-nav-chevron(aria-hidden="true")
                ul.admin-nav-sublist(role="list")
                    li.admin-nav-item
