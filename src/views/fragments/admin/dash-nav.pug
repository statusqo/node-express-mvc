    if postItemsCollected && postItemsCollected.length
        div(class="dash-footer")
            each item in postItemsCollected
                - var postAction = (item.url && item.url.indexOf('/auth') === 0) ? item.url : (adminPrefix || '') + item.url
                form(action=postAction method="POST" class="dash-form-inline")
                    button(type="submit" class="dash-logout")= item.label
    else
        div(class="dash-footer")
            form(action="/auth/logout" method="POST")
                button(type="submit" class="dash-logout") Logout
