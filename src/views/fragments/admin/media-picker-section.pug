//- Media picker component (COMPONENT_STANDARD)
//- Usage: include this file, then +mediaPickerSection({ inputName, attachedMedia, uploadsBaseUrl, apiUrl, label?, hint? })
mixin mediaPickerSection(options)
  - const inputName = options.inputName || 'mediaIds[]'
  - const attachedMedia = options.attachedMedia || []
  - const uploadsBaseUrl = options.uploadsBaseUrl || ''
  - const apiUrl = options.apiUrl || ''
  - const label = options.label != null ? options.label : 'Media'
  - const hint = options.hint
  div.admin-media-picker-section(
    data-media-picker
    data-input-name=inputName
    data-api-url=apiUrl
    data-uploads-base-url=uploadsBaseUrl
  )
    div.admin-form-group
      label= label
      if hint
        p.admin-form-hint.admin-media-picker-hint= hint
    div.admin-media-picker-attached
      each item in attachedMedia
        - const imgPath = uploadsBaseUrl + '/' + (item.path || '').replace(/\\/g, '/')
        div.admin-media-picker-attached-item(data-media-id=item.id)
          if item.mimeType && item.mimeType.startsWith("image/")
            img.admin-media-picker-thumb(src=imgPath alt=item.alt || item.filename || "" width="80" height="60")
          else
            span.admin-media-picker-placeholder File
          span.admin-media-picker-filename(title=item.filename || item.path)= item.filename || item.path || item.id
          button.admin-media-picker-remove(type="button" data-action="remove-attached" aria-label="Remove") Remove
        input(type="hidden" name=inputName value=item.id)
    button.admin-btn.admin-media-picker-open(type="button" data-action="open-media-picker") Select media
    div.admin-media-picker-modal(role="dialog" aria-modal="true" aria-labelledby="media-picker-title" hidden)
      div.admin-media-picker-modal-overlay(data-action="close-media-picker")
      div.admin-media-picker-modal-box
        h2#media-picker-title.admin-media-picker-modal-title Select media
        div.admin-media-picker-grid
        div.admin-media-picker-modal-actions
          button.admin-btn.admin-btn-primary.admin-media-picker-add-selected(type="button" data-action="add-selected") Add selected
          button.admin-btn.admin-media-picker-cancel(type="button" data-action="close-media-picker") Cancel
