extends ../../layouts/admin

block append links
    link(rel='stylesheet' href='/public/css/admin-dark.css')
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

mixin fieldRows(disabled, lockIsOnline)
    - var onlineLocked = !disabled && lockIsOnline && (event && event.isOnline)
    .da-form-section
        h2.da-form-section-label Date & time
        .da-form-group
            label.da-form-label(for='startDate')
                | Start date
                if !disabled
                    span.req *
            input#startDate.da-form-input(
                type='date'
                name='startDate'
                required=!disabled
                disabled=disabled
                value=event ? event.startDate : ''
                autofocus=!disabled
            )
        .da-form-group
            label.da-form-label(for='startTime') Start time
            input#startTime.da-form-input(
                type='time'
                name='startTime'
                disabled=disabled
                value=event && event.startTime ? String(event.startTime).substring(0, 5) : ''
            )
        .da-form-group
            label.da-form-label(for='durationMinutes') Duration (minutes)
            input#durationMinutes.da-form-input(
                type='number'
                name='durationMinutes'
                min='1'
                placeholder='e.g. 60'
                disabled=disabled
                value=event && event.durationMinutes != null ? event.durationMinutes : ''
            )
        .da-form-group
            label.da-form-label(for='timezone') Timezone
            input#timezone.da-form-input(
                type='text'
                name='timezone'
                placeholder='e.g. Europe/London'
                maxlength='64'
                readonly
                disabled=disabled
                value=event && event.timezone ? event.timezone : ''
            )

    .da-form-section
        h2.da-form-section-label Location & capacity
        .da-form-group
            label.da-form-label(for='location') Location
            input#location.da-form-input(
                type='text'
                name='location'
                placeholder='e.g. Zoom or room name'
                maxlength='255'
                disabled=disabled
                value=event ? event.location : ''
            )
        .da-form-group
            label.da-form-label(for='capacity') Capacity
            input#capacity.da-form-input(
                type='number'
                name='capacity'
                min='0'
                placeholder='0'
                disabled=disabled
                value=event && event.capacity != null ? event.capacity : ''
            )
            if !disabled
                - var regCount = event && event.registrationCount ? event.registrationCount : 0
                if regCount > 0
                    p.da-form-hint Must be at least #{regCount} (current registrant count).
                else
                    p.da-form-hint Maximum attendees. Leave 0 for unlimited.
        .da-form-group
            if onlineLocked
                input(type='hidden' name='isOnline' value='1')
            label.admin-checkbox
                input(
                    type='checkbox'
                    name='isOnline'
                    value='1'
                    checked=(event ? event.isOnline : false)
                    disabled=(disabled || onlineLocked)
                )
                | Online event (Zoom meeting can be created when syncing)
            if onlineLocked
                p.da-form-hint This event was created as an online event and cannot be changed to in-person.

mixin zoomCheckIcon
    svg(width='20' height='20' viewBox='0 0 20 20' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
        circle(cx='10' cy='10' r='9' fill='rgba(34,197,94,0.12)' stroke='#22C55E' stroke-width='1.5')
        path(d='M6.5 10.5l2.5 2.5 4.5-5' stroke='#22C55E' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round')

mixin zoomXIcon
    svg(width='20' height='20' viewBox='0 0 20 20' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
        circle(cx='10' cy='10' r='9' fill='rgba(245,158,11,0.12)' stroke='#F59E0B' stroke-width='1.5')
        path(d='M7 7l6 6M13 7l-6 6' stroke='#F59E0B' stroke-width='1.5' stroke-linecap='round')

mixin statusActiveIcon
    svg(width='20' height='20' viewBox='0 0 20 20' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
        circle(cx='10' cy='10' r='9' fill='rgba(34,197,94,0.12)' stroke='#22C55E' stroke-width='1.5')
        path(d='M6.5 10.5l2.5 2.5 4.5-5' stroke='#22C55E' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round')

mixin statusOrphanedIcon
    svg(width='20' height='20' viewBox='0 0 20 20' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
        circle(cx='10' cy='10' r='9' fill='rgba(245,158,11,0.12)' stroke='#F59E0B' stroke-width='1.5')
        line(x1='10' y1='6' x2='10' y2='11.5' stroke='#F59E0B' stroke-width='1.5' stroke-linecap='round')
        circle(cx='10' cy='14' r='0.75' fill='#F59E0B')

mixin statusCancelledIcon
    svg(width='20' height='20' viewBox='0 0 20 20' fill='none' xmlns='http://www.w3.org/2000/svg' aria-hidden='true')
        circle(cx='10' cy='10' r='9' fill='rgba(239,68,68,0.12)' stroke='#EF4444' stroke-width='1.5')
        path(d='M7 7l6 6M13 7l-6 6' stroke='#EF4444' stroke-width='1.5' stroke-linecap='round')

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        - var eventSubtitle = (product ? product.title : '') + (product && (product.priceAmount != null || product.currency) ? ' · Default: ' + (product.currency || 'USD') + ' ' + (product.priceAmount != null ? product.priceAmount : '—') : '')
        +pageHeader(isEdit ? 'Event Details' : 'New Event', eventSubtitle)
            +backBtn((adminPrefix || '') + '/' + sectionPath + '/' + product.slug + '/events', 'Back to Events')

        +formError(error)

        if isEdit
            - var baseEventsUrl = (adminPrefix || '') + '/' + sectionPath + '/' + product.slug + '/events'
            - var regCount = event.registrationCount || 0

            .da-form-grid

                //- ── Main: event fields ──────────────────────────────
                .da-form-main

                    //- Read-only (active / orphaned)
                    if event.eventStatus !== 'cancelled'
                        .da-card
                            .da-card-body
                                +fieldRows(true)

                    //- Reschedule form (cancelled events only)
                    else
                        .da-card
                            form#reschedule-event-form(
                                method='post'
                                action=baseEventsUrl + '/reschedule-event'
                            )
                                input(type='hidden' name='eventId' value=event.id)
                                .da-card-body
                                    +fieldRows(false, true)
                                .da-card-footer
                                    button.da-btn.da-btn--primary(
                                        type='button'
                                        data-confirm-modal
                                        data-confirm-title='Create Event'
                                        data-confirm-msg='This will create a new Zoom meeting and re-add all existing registrants. The event will be set to active.'
                                        data-form-id='reschedule-event-form'
                                    ) Create Event
                                    a.da-btn.da-btn--secondary(href=baseEventsUrl) Cancel

                //- ── Aside: status + danger zone ─────────────────────
                .da-form-aside

                    //- Actions card (always shown)
                    .da-card(class=(event.isOnline && event.meetingLinkStatus !== 'synced') ? 'da-card--warning-accent' : '')
                        .da-card-header
                            h2.da-card-title Actions
                        .da-card-body
                            //- Event status row
                            if event.eventStatus === 'active'
                                .da-event-zoom-status
                                    .da-event-zoom-status__icon
                                        +statusActiveIcon
                                    .da-event-zoom-status__content
                                        span.da-event-zoom-status__label This event is active
                            else if event.eventStatus === 'orphaned'
                                .da-event-zoom-status
                                    .da-event-zoom-status__icon
                                        +statusOrphanedIcon
                                    .da-event-zoom-status__content
                                        span.da-event-zoom-status__label This event is orphaned
                            else if event.eventStatus === 'cancelled'
                                .da-event-zoom-status
                                    .da-event-zoom-status__icon
                                        +statusCancelledIcon
                                    .da-event-zoom-status__content
                                        span.da-event-zoom-status__label This event is cancelled

                            //- Zoom meeting status (online events only)
                            if event.isOnline
                                hr.da-card-divider
                                if event.meetingLinkStatus === 'synced'
                                    .da-event-zoom-status
                                        .da-event-zoom-status__icon
                                            +zoomCheckIcon
                                        .da-event-zoom-status__content
                                            span.da-event-zoom-status__label Active Zoom meeting
                                else
                                    .da-event-zoom-status
                                        .da-event-zoom-status__icon
                                            +zoomXIcon
                                        .da-event-zoom-status__content
                                            span.da-event-zoom-status__label No Zoom meeting
                                            if event.eventStatus === 'cancelled'
                                                span.da-event-zoom-status__hint The meeting was removed when the event was cancelled. Reschedule the event to create a new one.
                                            else if event.eventStatus === 'orphaned'
                                                span.da-event-zoom-status__hint The meeting was deleted externally.
                                                form#resync-zoom-form(method='post' action=baseEventsUrl + '/resync-event')
                                                    input(type='hidden' name='eventId' value=event.id)
                                                    button.da-btn.da-btn--secondary(type='submit') Re-sync with Zoom
                                            else
                                                span.da-event-zoom-status__hint No meeting has been created yet.

                    //- Danger zone
                    .da-card.da-danger-zone
                        .da-card-header
                            h2.da-card-title Danger Zone
                        .da-card-body
                            if event.eventStatus === 'active' || event.eventStatus === 'orphaned'
                                - var cancelBullets = event.isOnline ? ['Zoom meeting will be deleted', 'Event will be marked as cancelled'] : ['Event will be marked as cancelled']
                                .da-danger-zone-item
                                    p.da-danger-zone-desc
                                        | #{event.isOnline ? 'Removes the Zoom meeting and marks this event as cancelled.' : 'Marks this event as cancelled.'} Registrations and orders are not affected.
                                    form#cancel-event-form(method='post' action=baseEventsUrl + '/cancel-event')
                                        input(type='hidden' name='eventId' value=event.id)
                                        input(type='hidden' name='confirm' value='1')
                                        button.da-btn.da-btn--danger(
                                            type='button'
                                            data-confirm-modal
                                            data-confirm-title='Cancel Event'
                                            data-confirm-msg='The following will happen immediately:'
                                            data-confirm-bullets=JSON.stringify(cancelBullets)
                                            data-form-id='cancel-event-form'
                                        ) Cancel Event

                            if event.eventStatus === 'cancelled' && regCount > 0
                                - var refundBullets = ['Paid orders will be refunded via Stripe', 'Unpaid orders will be voided', 'Registration records will be cleared']
                                .da-danger-zone-item
                                    p.da-danger-zone-desc Refunds all registrants via Stripe and clears registration records.
                                    form#process-refunds-form(method='post' action=baseEventsUrl + '/process-refunds')
                                        input(type='hidden' name='eventId' value=event.id)
                                        input(type='hidden' name='confirm' value='1')
                                        button.da-btn.da-btn--danger(
                                            type='button'
                                            data-confirm-modal
                                            data-confirm-title='Refund Event'
                                            data-confirm-msg=regCount + ' registration(s) will be processed. This cannot be undone:'
                                            data-confirm-bullets=JSON.stringify(refundBullets)
                                            data-form-id='process-refunds-form'
                                        ) Refund Event
                                hr.da-danger-zone-sep

                            if event.eventStatus === 'cancelled'
                                .da-danger-zone-item
                                    p.da-danger-zone-desc Permanently deletes this event and all associated data.
                                    form#remove-event-form(method='post' action=baseEventsUrl + '/remove-event')
                                        input(type='hidden' name='eventId' value=event.id)
                                        button.da-btn.da-btn--danger(
                                            type='button'
                                            data-confirm-modal
                                            data-confirm-title='Remove Event'
                                            data-confirm-msg='Remove this event permanently? This cannot be undone.'
                                            data-form-id='remove-event-form'
                                        ) Remove Event

        //- ── New event form (no aside needed) ────────────────────────
        else
            .da-card(style='max-width: 640px;')
                form(
                    method='post'
                    action=(adminPrefix || '') + '/' + sectionPath + '/' + product.slug + '/events/new'
                )
                    .da-card-body
                        +fieldRows(false)
                    .da-card-footer
                        button.da-btn.da-btn--primary(type='submit') Create Event
                        a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/' + sectionPath + '/' + product.slug + '/events') Cancel

block append scripts
    script(src='/public/js/admin-event-form.js')
