extends ../../layouts/admin

block content
    - var fmtDate = function(d) { return d ? new Date(d).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'; }
    - var fmtTime = function(d) { return d ? new Date(d).toLocaleTimeString('en-GB', {hour:'2-digit', minute:'2-digit'}) : ''; }
    - var dateParts = event.startDate ? String(event.startDate).substring(0, 10).split('-') : null
    - var dateFormatted = dateParts && dateParts.length === 3 ? dateParts[2] + '/' + dateParts[1] + '/' + dateParts[0] : '—'
    - var timeFormatted = event.startTime ? String(event.startTime).substring(0, 5) : '—'
    - var productTitle = event.Product ? event.Product.title : 'Event'

    .da-page

        //- ── Page header ─────────────────────────────────────────────
        - var subtitle = dateFormatted + (timeFormatted !== '—' ? ' · ' + timeFormatted : '') + ' · ' + productTitle
        +pageHeader('Registrants', subtitle)
            +backBtn((adminPrefix || '') + '/events', 'Back to Events')

        //- ── Event summary card ───────────────────────────────────────
        .da-panel(style='margin-bottom: 1.5rem')
            +eventSummaryCard(event, paidRegistrantCount != null ? paidRegistrantCount : 0)

        //- ── Registrants table ───────────────────────────────────────
        .da-panel
            .da-table-scroll
                table.da-table(role='table' aria-label='Registrants list')
                    thead
                        tr
                            th(scope='col') Name
                            th(scope='col') Email
                            th(scope='col') Order
                            th(scope='col') Payment
                            th.da-col-created(scope='col') Registered On
                            th(scope='col' style='text-align: right') Actions
                    tbody
                        if registrants && registrants.length
                            each r in registrants
                                - var fullName = [r.forename, r.surname].filter(Boolean).join(' ') || '—'
                                - var email = r.email || (r.User && r.User.email) || '—'
                                - var payClass = ({paid:'success', pending:'warning', failed:'danger', refunded:'info', cancelled:'neutral'})[r.Order && r.Order.paymentStatus] || 'neutral'
                                - var editUrl = (adminPrefix || '') + '/events/' + event.id + '/registrants/' + r.id + '/edit'
                                tr
                                    td
                                        span.da-cell-secondary= fullName
                                    td
                                        span.da-cell-muted= email
                                    td
                                        if r.Order && r.Order.orderNumber
                                            a.da-order-link(
                                                href=(adminPrefix || '') + '/orders/' + r.Order.id + '/edit'
                                                aria-label='View order #' + r.Order.orderNumber
                                            )
                                                span.da-cell-mono= '#' + r.Order.orderNumber
                                        else if r.Order
                                            a.da-order-link(
                                                href=(adminPrefix || '') + '/orders/' + r.Order.id + '/edit'
                                                aria-label='View order'
                                            )
                                                span.da-cell-mono= r.Order.id.slice(0, 8) + '...'
                                        else
                                            span.da-cell-muted —
                                    td
                                        if r.Order && r.Order.paymentStatus
                                            span.da-badge(class='da-badge--' + payClass)= r.Order.paymentStatus.charAt(0).toUpperCase() + r.Order.paymentStatus.slice(1)
                                        else
                                            span.da-cell-muted —
                                    td.da-col-created
                                        .da-date-cell
                                            span.da-cell-muted= fmtDate(r.createdAt)
                                            if r.createdAt
                                                span.da-date-time= fmtTime(r.createdAt)
                                    td
                                        .da-cell-actions
                                            a.da-row-btn.da-row-btn--edit(
                                                href=editUrl
                                                aria-label='Edit registrant ' + (r.id ? r.id.slice(0, 8) : '')
                                            ) Edit
                        else
                            +tableEmpty('No registrants for this event.', 6)
