extends ../../layouts/admin

block append links
    link(rel='stylesheet' href='/public/css/admin-dark.css')

block content
    include ../../fragments/admin/event-components

    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader('Events', categories ? categories.length + ' categor' + (categories.length === 1 ? 'y' : 'ies') : '0 categories')

        //- ── Category cards ──────────────────────────────────────────
        if categories && categories.length
            .da-category-grid
                each cat in categories
                    +eventCategoryCard(cat, adminPrefix)
        else
            .da-panel
                .da-table-empty
                    svg(xmlns='http://www.w3.org/2000/svg' width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        rect(x='3' y='4' width='18' height='18' rx='2' ry='2')
                        line(x1='16' y1='2' x2='16' y2='6')
                        line(x1='8' y1='2' x2='8' y2='6')
                        line(x1='3' y1='10' x2='21' y2='10')
                    span No event categories found. Assign ProductType&nbsp;
                        strong Event
                        |  to products to have them appear here.
