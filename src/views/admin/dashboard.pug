extends ../layouts/admin

block append links
    link(rel='stylesheet' href='/public/css/admin-dark.css')
    link(rel='stylesheet' href='/public/css/dashboard.css')

block append scripts
    script(src='/public/js/dashboard.js')

block content
    include ../fragments/admin/dash-components

    .da-page

        //- ── Search Bar ───────────────────────────────────────────────
        .dash-search-row
            label.dash-search(for='dash-search-input' aria-label='Search admin panel')
                span.dash-search-icon(aria-hidden='true')
                    svg(xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
                        circle(cx='11' cy='11' r='8')
                        line(x1='21' y1='21' x2='16.65' y2='16.65')
                input#dash-search-input.dash-search-input(
                    type='text'
                    placeholder='Search products, orders, users…'
                    autocomplete='off'
                    aria-label='Search admin panel'
                )
                kbd.dash-search-kbd
                    span Ctrl
                    span K

        //- ── KPI Cards ────────────────────────────────────────────────
        .dash-kpi-grid
            +kpiCardDelta((adminPrefix || '') + '/orders',          Math.round(stats.revenueThisMonth || 0),  'Revenue This Month',  'trending-up',  'accent',   stats.revenueDelta,   '€')
            +kpiCardDelta((adminPrefix || '') + '/orders',          Math.round(stats.netRevenueThisMonth || 0), 'Net Revenue This Month',       'dollar-sign',  'success',  null,                 '€')
            +kpiCardDelta((adminPrefix || '') + '/orders',          stats.ordersThisMonth || 0,               'Orders This Month',   'shopping-bag', 'info',     stats.ordersDelta)
            +kpiCardDelta((adminPrefix || '') + '/users',           stats.newUsersThisMonth || 0,             'New Users This Month',           'user-plus',    'warning',  stats.newUsersDelta)

        //- ── Actionable Orders ────────────────────────────────────────
        section.da-panel
            .dash-panel-header
                h2.dash-panel-title Requires Action
                a.dash-panel-action(href=(adminPrefix || '') + '/orders') View all →
            .da-table-scroll
                table.da-table(role='table' aria-label='Orders requiring action')
                    thead
                        tr
                            th(scope='col') Order
                            th(scope='col') Customer
                            th(scope='col') Total
                            th(scope='col') Status
                            th(scope='col') Age
                            th(scope='col')
                    tbody
                        if stats.actionableOrders && stats.actionableOrders.length
                            each order in stats.actionableOrders
                                - var ageMs = Date.now() - new Date(order.createdAt).getTime()
                                - var ageDays = Math.floor(ageMs / 86400000)
                                - var ageLabel = ageDays === 0 ? 'Today' : ageDays === 1 ? '1 day ago' : ageDays + ' days ago'
                                - var statusCls = order.fulfillmentStatus === 'refund_requested' ? 'danger' : order.fulfillmentStatus === 'processing' ? 'info' : 'warning'
                                tr
                                    td
                                        a.da-cell-mono(href=(adminPrefix || '') + '/orders/' + order.id) ##{order.orderNumber || order.id.slice(0,8)}
                                    td.da-cell-primary= order.forename ? (order.forename + ' ' + (order.surname || '')).trim() : (order.email || '—')
                                    td.da-cell-primary €#{parseFloat(order.total || 0).toFixed(2)}
                                    td
                                        span.da-badge(class='da-badge--' + statusCls)= order.fulfillmentStatus.split('_').map(function(w){ return w.charAt(0).toUpperCase() + w.slice(1) }).join(' ')
                                    td.da-cell-muted= ageLabel
                                    td
                                        .da-cell-actions
                                            a.da-row-btn.da-row-btn--edit(
                                                href=(adminPrefix || '') + '/orders/' + order.id + '/edit'
                                                aria-label='Edit order ' + (order.orderNumber ? '#' + order.orderNumber : order.id.slice(0, 8))
                                            ) Edit
                        else
                            tr
                                td.da-table-empty(colspan='6') No orders pending action.
