extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader('Edit Order', order.orderNumber ? '#' + order.orderNumber : 'Order details')
            +backBtn((adminPrefix || '') + '/orders', 'Back to Orders')

        +formError(error)

        //- ── Two-column grid: form main + refund aside ───────────────
        .da-form-grid

            //- ── Main column: order sections ─────────────────────────
            .da-form-main

                //- ── Card 1: Order ───────────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Order
                    .da-card-body
                        .da-form-section
                            span.da-form-section-label Identity
                            +readonlyField('Order Number')
                                span.da-cell-mono= order.orderNumber ? '#' + order.orderNumber : '—'
                            +readonlyField('Internal ID')
                                span.da-cell-mono= order.id || '—'
                            +readonlyField('Date')
                                | #{order.createdAt ? new Date(order.createdAt).toLocaleString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'}) : '—'}
                            +readonlyField('Source')
                                if order.source === 'event'
                                    span.da-badge.da-badge--info Event checkout
                                else
                                    span Cart
                        .da-form-section
                            span.da-form-section-label Customer
                            +readonlyField('Name / Email')
                                | #{order.email || (order.forename || order.surname ? (order.forename || '') + ' ' + (order.surname || '') : order.userId ? 'User #' + order.userId : 'Guest') || '—'}
                            +readonlyField('Person Type')
                                if order.personType === 'legal'
                                    span.da-badge.da-badge--info Legal person
                                else
                                    span Private person
                            if order.personType === 'legal'
                                +readonlyField('Company Name')
                                    | #{order.companyName || '—'}
                                +readonlyField('OIB')
                                    | #{order.companyOib || '—'}

                //- ── Card 2: Payment ─────────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Payment
                    .da-card-body
                        .da-form-section
                            span.da-form-section-label Status &amp; Totals
                            +readonlyField('Payment Status')
                                - var payClass = ({paid:'success',pending:'warning',failed:'danger',refunded:'info',partially_refunded:'info',voided:'neutral',cancelled:'neutral'})[order.paymentStatus] || 'neutral'
                                if order.paymentStatus
                                    span.da-badge(class='da-badge--' + payClass)= order.paymentStatus.split('_').map(function(w){ return w.charAt(0).toUpperCase() + w.slice(1) }).join(' ')
                                else
                                    span —
                            +readonlyField('Total')
                                | #{order.total != null ? Number(order.total).toFixed(2) + ' ' + (order.currency || 'EUR') : '—'}
                            +readonlyField('Refunded to date')
                                | #{orderRefundedTotal != null ? Number(orderRefundedTotal).toFixed(2) + ' ' + (order.currency || 'EUR') : '—'}
                            +readonlyField('Remaining refundable')
                                | #{orderRemainingRefundable != null ? Number(orderRemainingRefundable).toFixed(2) + ' ' + (order.currency || 'EUR') : '—'}
                            +readonlyField('Stripe PaymentIntent')
                                if order.stripePaymentIntentId
                                    span.da-cell-mono= order.stripePaymentIntentId
                                else
                                    span.da-cell-muted —
                        if transactions && transactions.length
                            .da-form-section
                                span.da-form-section-label Transactions
                                .da-table-scroll(style='margin-top:0.5rem')
                                    table.da-table(role='table' aria-label='Transactions')
                                        thead
                                            tr
                                                th(scope='col') Status
                                                th(scope='col') Amount
                                                th(scope='col') Gateway reference
                                                th.da-col-created(scope='col') Created
                                        tbody
                                            each tx in transactions
                                                tr
                                                    td
                                                        if tx.status
                                                            span.da-badge(class='da-badge--' + ({success:'success',pending:'warning',failed:'danger',refunded:'info'})[tx.status] || 'neutral')= tx.status.charAt(0).toUpperCase() + tx.status.slice(1)
                                                        else
                                                            span —
                                                    td= tx.amount != null ? Number(tx.amount).toFixed(2) + ' ' + (tx.currency || order.currency || 'EUR') : '—'
                                                    td
                                                        span.da-cell-mono= tx.gatewayReference || '—'
                                                    td.da-col-created
                                                        span.da-cell-muted= tx.createdAt ? new Date(tx.createdAt).toLocaleString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'}) : '—'
                        if orderDiscount
                            .da-form-section
                                span.da-form-section-label Discount
                                .da-table-scroll(style='margin-top:0.5rem')
                                    table.da-table(role='table' aria-label='Discount')
                                        thead
                                            tr
                                                th(scope='col') Code
                                                th(scope='col') Type &amp; value
                                                th(scope='col') Amount deducted
                                        tbody
                                            tr
                                                td
                                                    code(style='font-size:0.9rem;letter-spacing:0.04em')= orderDiscount.code
                                                td= orderDiscount.type === 'percentage' ? Number(orderDiscount.value) + '% off' : '€' + Number(orderDiscount.value).toFixed(2) + ' off'
                                                td(style='font-weight:600;color:var(--ds-success,#22C55E)')
                                                    | −€#{Number(orderDiscount.amountDeducted).toFixed(2)}

                //- ── Card 3: Line Items ──────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Line Items
                    .da-card-body
                        if orderLines && orderLines.length
                            - var _eventLines = orderLines.filter(function(l){ return l.eventId != null && String(l.eventId).trim() !== '' })
                            - var _productLines = orderLines.filter(function(l){ return !(l.eventId != null && String(l.eventId).trim() !== '') })
                            - var _hasBoth = _eventLines.length > 0 && _productLines.length > 0

                            //- ── Event registrations ─────────────────────
                            if _eventLines.length
                                .da-table-scroll
                                    table.da-table(role='table' aria-label='Event registrations')
                                        thead
                                            tr
                                                th(scope='col') Event Lines
                                                th(scope='col') Qty
                                                th(scope='col') Unit price
                                                th(scope='col') SKU
                                        tbody
                                            each line in _eventLines
                                                - var lineAttendees = attendeesByLine[line.id] || []
                                                - var lineRowClass = line.fullyRefunded ? 'da-row--refunded' : ''
                                                tr(class=lineRowClass)
                                                    td= line.displayTitle || line.title || '—'
                                                    td= line.quantity != null ? line.quantity : '—'
                                                    td= line.price != null ? Number(line.price).toFixed(2) + ' ' + (order.currency || 'EUR') : '—'
                                                    td
                                                        span.da-cell-mono= line.sku || '—'
                                                each attendee in lineAttendees
                                                    - var attName = ((attendee.forename || '') + ' ' + (attendee.surname || '')).trim()
                                                    - var _attCancelled = attendee.refunded || attendee.registrationCancelled
                                                    - var attClass = 'da-attendee-row' + (_attCancelled ? ' da-row--refunded' : '')
                                                    tr(class=attClass)
                                                        td(colspan='4')
                                                            .da-attendee-cell
                                                                .da-attendee-info
                                                                    span.da-attendee-name= attName || '—'
                                                                    if attendee.email
                                                                        span.da-attendee-email= attendee.email
                                                                .da-attendee-actions
                                                                    if attendee.refunded
                                                                        span.da-badge.da-badge--danger(style='font-size:11px') Refunded
                                                                    else if attendee.registrationCancelled
                                                                        span.da-badge.da-badge--warning(style='font-size:11px') Cancelled
                                                                    if attendee.registrationId && !attendee.registrationCancelled
                                                                        a.da-row-btn.da-row-btn--edit(
                                                                            href=(adminPrefix || '') + '/events/' + attendee.eventId + '/registrants/' + attendee.registrationId + '/edit'
                                                                        ) Edit

                            //- ── Divider ─────────────────────────────────
                            if _hasBoth
                                hr(style='margin:1.25rem 0;border:none;border-top:1px solid var(--ds-border)')

                            //- ── Product lines ───────────────────────────
                            if _productLines.length
                                .da-table-scroll
                                    table.da-table(role='table' aria-label='Product lines')
                                        thead
                                            tr
                                                th(scope='col') Product Lines
                                                th(scope='col') Qty
                                                th(scope='col') Unit price
                                                th(scope='col') SKU
                                        tbody
                                            each line in _productLines
                                                - var lineRowClass = line.fullyRefunded ? 'da-row--refunded' : ''
                                                tr(class=lineRowClass)
                                                    td
                                                        = line.displayTitle || line.title || '—'
                                                        if line.partiallyRefunded
                                                            span.da-refund-pill #{line.refundedQty} of #{line.quantity} refunded
                                                    td= line.quantity != null ? line.quantity : '—'
                                                    td= line.price != null ? Number(line.price).toFixed(2) + ' ' + (order.currency || 'EUR') : '—'
                                                    td
                                                        span.da-cell-mono= line.sku || '—'

                            //- ── Refund notices ──────────────────────────
                            if fullOrderRefunds && fullOrderRefunds.length
                                each fr in fullOrderRefunds
                                    .da-full-refund-notice
                                        svg(width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                                            circle(cx='12' cy='12' r='10')
                                            line(x1='12' y1='8' x2='12' y2='12')
                                            line(x1='12' y1='16' x2='12.01' y2='16')
                                        | Full order refund —&nbsp;
                                        strong #{Number(fr.amount).toFixed(2)} #{fr.currency || order.currency || 'EUR'}
                                        | &nbsp;issued on #{new Date(fr.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'})}
                            - var _partialRefundTxs = order.paymentStatus !== 'refunded' ? (refundTransactions || []).filter(function(rt){ return rt.status === 'succeeded' && rt.scopeType !== 'full_order' }) : []
                            each pr in _partialRefundTxs
                                .da-partial-refund-notice
                                    svg(width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                                        circle(cx='12' cy='12' r='10')
                                        line(x1='12' y1='8' x2='12' y2='12')
                                        line(x1='12' y1='16' x2='12.01' y2='16')
                                    | Partial refund —&nbsp;
                                    strong #{Number(pr.amount).toFixed(2)} #{pr.currency || order.currency || 'EUR'}
                                    | &nbsp;issued on #{new Date(pr.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'})}
                            if order.paymentStatus === 'refunded' && !(fullOrderRefunds && fullOrderRefunds.length)
                                .da-full-refund-notice
                                    svg(width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                                        circle(cx='12' cy='12' r='10')
                                        line(x1='12' y1='8' x2='12' y2='12')
                                        line(x1='12' y1='16' x2='12.01' y2='16')
                                    | Full order refund —&nbsp;
                                    strong #{Number(orderRefundedTotal || 0).toFixed(2)} #{order.currency || 'EUR'}
                                    | &nbsp;total refunded
                        else
                            p.da-refund-empty No line items for this order.

                //- ── Card 4: Addresses ───────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Addresses
                    .da-card-body
                        +readonlyField('Delivery Address')
                            - var delivery = [order.deliveryLine1, order.deliveryLine2, [order.deliveryCity, order.deliveryState, order.deliveryPostcode].filter(Boolean).join(', '), order.deliveryCountry].filter(Boolean).join(' · ')
                            | #{delivery || '—'}
                        +readonlyField('Billing Address')
                            - var billing = [order.billingLine1, order.billingLine2, [order.billingCity, order.billingState, order.billingPostcode].filter(Boolean).join(', '), order.billingCountry].filter(Boolean).join(' · ')
                            | #{billing || '—'}

                //- ── Card 5: Fulfillment ─────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Fulfillment
                    .da-card-body
                        form#orderEditForm(
                            method='post'
                            action=(adminPrefix || '') + '/orders/' + order.id + '/edit'
                        )
                            .da-form-group
                                label.da-form-label(for='fulfillmentStatus')
                                    | Fulfillment Status
                                    span.req *
                                select#fulfillmentStatus.da-form-select(name='fulfillmentStatus' required)
                                    each s in validFulfillmentStatuses
                                        option(value=s selected=(order.fulfillmentStatus === s))= s.split('_').map(function(w){ return w.charAt(0).toUpperCase() + w.slice(1) }).join(' ')

                //- ── Form footer bar ─────────────────────────────────
                .da-form-footer-bar
                    button.da-btn.da-btn--primary(type='submit' form='orderEditForm') Save Changes
                    a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/orders') Cancel

            //- ── Aside: alerts + actions + refund requests + danger ───
            .da-form-aside

                //- ── Order Alerts card ────────────────────────────────
                - var _orderAlerts = []
                - if (hasActiveRegistrations) _orderAlerts.push('This order has ' + activeRegistrationCount + ' active event registration' + (activeRegistrationCount !== 1 ? 's' : '') + '.')
                .da-card
                    .da-card-header
                        h2.da-card-title Alerts
                        if _orderAlerts.length
                            span.da-count= _orderAlerts.length
                    .da-card-body
                        if _orderAlerts.length
                            ul(style='list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.65rem')
                                each alertMsg in _orderAlerts
                                    li(style='display:flex;align-items:flex-start;gap:0.5rem;font-size:0.8125rem;line-height:1.5;color:var(--ds-warning,#F59E0B)')
                                        span(aria-hidden='true' style='flex-shrink:0;line-height:1.3') ●
                                        span= alertMsg
                        else
                            p.da-refund-empty(style='margin-top:0') No alerts for this order.

                - var _hasAlert = canRetryFinalize || canRetryZoom || (canResendEmail && !emailSent)
                - var _hasActions = canRetryFinalize || canRetryZoom || canResendEmail
                .da-card(style=_hasAlert ? 'border-color:var(--ds-warning,#F59E0B)' : '')
                    .da-card-header(style=_hasAlert ? 'background:rgba(245,158,11,0.08)' : '')
                        h2.da-card-title(style=_hasAlert ? 'color:var(--ds-warning,#F59E0B)' : '') Actions
                    .da-card-body(style='display:flex;flex-direction:column;gap:0.75rem')
                        if canRetryFinalize
                            .da-action-item
                                p.da-action-desc(style='color:var(--ds-warning,#F59E0B)')
                                    | Stripe charged the customer but the order stayed pending. Finalising will update inventory, create registrations, and mark the order as paid.
                                - var finalizeFormId = 'finalize-payment-form-' + order.id
                                form(id=finalizeFormId method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/finalize-payment')
                                    button.da-btn.da-btn--warning(
                                        type='button'
                                        data-confirm-modal
                                        data-confirm-title='Finalize Payment'
                                        data-confirm-msg='Mark this order as paid and run inventory and registration fulfillment. Only use this if you have confirmed the customer was charged in Stripe.'
                                        data-form-id=finalizeFormId
                                    ) Finalize payment
                        if canRetryZoom
                            .da-action-item
                                p.da-action-desc(style='color:var(--ds-warning,#F59E0B)')
                                    | Zoom sync did not complete after payment. Click to retry adding this order's registrants to their Zoom meetings.
                                - var retryZoomFormId = 'retry-zoom-form-' + order.id
                                form(id=retryZoomFormId method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/retry-zoom')
                                    button.da-btn.da-btn--warning(
                                        type='button'
                                        data-confirm-modal
                                        data-confirm-title='Retry Zoom Sync'
                                        data-confirm-msg='Re-run Zoom sync for all registrants on this order. Safe to run more than once.'
                                        data-form-id=retryZoomFormId
                                    ) Retry Zoom Sync
                        if canResendEmail
                            .da-action-item
                                p.da-action-desc(style='color:' + (!emailSent ? 'var(--ds-warning,#F59E0B)' : 'var(--ds-text-3)'))
                                    | #{!emailSent ? 'Confirmation email was not sent after payment.' : 'Resend the order confirmation email to the customer.'}
                                - var resendEmailFormId = 'resend-email-form-' + order.id
                                form(id=resendEmailFormId method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/resend-confirmation-email')
                                    button(
                                        class='da-btn ' + (!emailSent ? 'da-btn--warning' : 'da-btn--secondary')
                                        type='button'
                                        data-confirm-modal
                                        data-confirm-title='Resend Confirmation Email'
                                        data-confirm-msg='Send the order confirmation email to the customer again. Safe to run more than once.'
                                        data-form-id=resendEmailFormId
                                    ) Resend Confirmation Email
                        if !_hasActions
                            p.da-refund-empty(style='margin-top:0') No actions to perform for this order.

                .da-card
                    .da-card-header
                        h2.da-card-title Refund Requests
                        if refundRequests && refundRequests.length
                            span.da-count= refundRequests.length
                    .da-card-body
                        if refundRequests && refundRequests.length
                            - var _pendingRR = refundRequests.filter(function(r){ return r.status === 'pending' })
                            - var _resolvedRR = refundRequests.filter(function(r){ return r.status !== 'pending' })
                            if _pendingRR.length
                                if orderHasEventLines
                                    - var approveConfirmMsg = 'Issue a Stripe refund for the remaining balance and complete this request. This order includes event lines: Zoom registrants are removed first, then Stripe refunds; registrations are cleared and inventory restored when the refund succeeds.'
                                    - var approveConfirmBullets = JSON.stringify(['Remove Zoom access for online events (before Stripe)', 'Stripe refund for the remaining capture balance', 'Clear registrations and restore inventory when Stripe confirms'])
                                else
                                    - var approveConfirmMsg = 'Issue a Stripe refund for the remaining balance and complete this request. Inventory and order records update when the refund succeeds.'
                                    - var approveConfirmBullets = JSON.stringify(['Stripe refund for the remaining capture balance', 'Inventory and order updated when the refund completes'])
                                each r in _pendingRR
                                    .da-refund-card
                                        .da-refund-card-header
                                            span.da-badge.da-badge--warning Pending
                                        p.da-refund-meta
                                            strong Requested:&nbsp;
                                            | #{r.createdAt ? new Date(r.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'}
                                        .da-refund-actions
                                            - var approveFormId = 'approve-refund-form-' + r.id
                                            form(id=approveFormId method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/refund-request/' + r.id + '/approve')
                                                button.da-btn.da-btn--primary(
                                                    type='button'
                                                    data-confirm-modal
                                                    data-confirm-title='Approve Refund'
                                                    data-confirm-msg=approveConfirmMsg
                                                    data-confirm-bullets=approveConfirmBullets
                                                    data-form-id=approveFormId
                                                ) Approve
                                            - var rejectFormId = 'reject-refund-form-' + r.id
                                            form(id=rejectFormId method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/refund-request/' + r.id + '/reject')
                                                button.da-btn.da-btn--danger(
                                                    type='button'
                                                    data-confirm-modal
                                                    data-confirm-title='Reject Refund Request'
                                                    data-confirm-msg='This will reject the refund request and return the order to delivered status.'
                                                    data-form-id=rejectFormId
                                                ) Reject
                            if _resolvedRR.length
                                if _pendingRR.length
                                    hr(style='margin:0.85rem 0;border:none;border-top:1px solid var(--ds-border)')
                                ul(style='list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:0.5rem')
                                    each r in _resolvedRR
                                        - var _rApproved = r.status === 'approved'
                                        - var _rDate = r.processedAt ? new Date(r.processedAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : (r.createdAt ? new Date(r.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—')
                                        li(style='display:flex;align-items:center;gap:0.5rem;font-size:0.8125rem;line-height:1.4')
                                            span(aria-hidden='true' style='flex-shrink:0;color:' + (_rApproved ? 'var(--ds-success,#22C55E)' : 'var(--ds-danger,#EF4444)')) ●
                                            span(style='color:' + (_rApproved ? 'var(--ds-success,#22C55E)' : 'var(--ds-danger,#EF4444)') + ';font-weight:600')= r.status.charAt(0).toUpperCase() + r.status.slice(1)
                                            span(style='color:var(--ds-text-3)') &mdash; #{_rDate}
                        else
                            p.da-refund-empty No refund requests for this order.

                - var _refundCur = order.currency || 'EUR'
                - var _refundedSum = orderRefundedTotal != null ? Number(orderRefundedTotal) : 0
                - var _remainingSum = orderRemainingRefundable != null ? Number(orderRemainingRefundable) : 0
                .da-card
                    .da-card-header
                        h2.da-card-title Danger Zone
                    .da-card-body
                        if canCancelAndRefundOrder
                            p.da-refund-empty(style='margin-top:0')
                                | Refunds the <strong>remaining</strong> balance (
                                strong #{_remainingSum.toFixed(2)} #{_refundCur}
                                | ) after #{_refundedSum.toFixed(2)} #{_refundCur} already recorded as refunded.
                            - var cancelRefundFormId = 'admin-order-cancel-refund-form'
                            - var cancelRefundMsg = 'Cancel and refund ' + _remainingSum.toFixed(2) + ' ' + _refundCur + '? This cannot be undone.'
                            if orderHasEventLines
                                - var cancelRefundBullets = ['Remove Zoom access for online events (before Stripe)', 'Stripe refund for the remaining capture balance', 'Clear registrations and restore inventory when Stripe confirms']
                            else
                                - var cancelRefundBullets = ['Stripe refund for the remaining capture balance', 'Inventory and order updated when the refund completes']
                            div(style='display:flex;justify-content:center;margin:0;padding:0')
                                form(id=cancelRefundFormId method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/cancel-and-refund' style='display:none')
                                button.da-btn.da-btn--danger(
                                    type='button'
                                    data-confirm-modal
                                    data-confirm-title='Cancel & Refund Order'
                                    data-confirm-msg=cancelRefundMsg
                                    data-confirm-bullets=JSON.stringify(cancelRefundBullets)
                                    data-form-id=cancelRefundFormId
                                ) Cancel &amp; Refund Order
                        else if canFullRefund
                            p.da-refund-empty(style='margin-top:0')
                                | Order is eligible for a refund but cannot use this action (e.g. fulfillment already refunded or no remaining balance).
                        else
                            p.da-refund-empty(style='margin-top:0')
                                | No remaining balance to refund, or the order is not in a refundable payment state.

