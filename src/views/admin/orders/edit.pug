extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader('Edit Order', order.orderNumber ? '#' + order.orderNumber : 'Order details')
            +backBtn((adminPrefix || '') + '/orders', 'Back to Orders')

        +formError(error)

        //- ── Active registrations warning banner ─────────────────────
        if hasActiveRegistrations
            - var bannerMsg = 'This order has ' + activeRegistrationCount + ' event registration' + (activeRegistrationCount !== 1 ? 's' : '') + '. Use Cancel & Refund Order to remove Zoom access, refund the remaining balance, and clear registrations (or cancel seats individually from the event registrant page first if you need partial refunds only).'
            .da-alert.da-alert--warning(role='alert')
                span.da-alert__icon
                    svg(width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        path(d='M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z')
                        line(x1='12' y1='9' x2='12' y2='13')
                        line(x1='12' y1='17' x2='12.01' y2='17')
                span= bannerMsg

        //- ── Two-column grid: form main + refund aside ───────────────
        .da-form-grid

            //- ── Main column: order details ──────────────────────────
            .da-form-main

                .da-card
                    .da-card-header
                        h2.da-card-title Order Details
                    .da-card-body
                        form#orderEditForm(
                            method='post'
                            action=(adminPrefix || '') + '/orders/' + order.id + '/edit'
                        )
                            .da-form-section
                                span.da-form-section-label Identity

                                //- Order number (read-only)
                                +readonlyField('Order Number')
                                    span.da-cell-mono= order.orderNumber ? '#' + order.orderNumber : '—'

                                //- Internal UUID (read-only)
                                +readonlyField('Internal ID')
                                    span.da-cell-mono= order.id || '—'

                                //- Customer (read-only)
                                +readonlyField('Customer')
                                    | #{order.email || (order.forename || order.surname ? (order.forename || '') + ' ' + (order.surname || '') : order.userId ? 'User #' + order.userId : 'Guest') || '—'}

                                //- Person type
                                +readonlyField('Person Type')
                                    if order.personType === 'legal'
                                        span.da-badge.da-badge--info Legal person
                                    else
                                        span Private person

                                //- Company info (legal persons only)
                                if order.personType === 'legal'
                                    +readonlyField('Company Name')
                                        | #{order.companyName || '—'}
                                    +readonlyField('OIB')
                                        | #{order.companyOib || '—'}

                                //- Payment status (read-only with badge)
                                +readonlyField('Payment Status')
                                    - var payClass = ({paid:'success',pending:'warning',failed:'danger',refunded:'info',partially_refunded:'info',voided:'neutral',cancelled:'neutral'})[order.paymentStatus] || 'neutral'
                                    if order.paymentStatus
                                        span.da-badge(class='da-badge--' + payClass)= order.paymentStatus.charAt(0).toUpperCase() + order.paymentStatus.slice(1)
                                    else
                                        span —

                                //- Total (read-only)
                                +readonlyField('Total')
                                    | #{order.total != null ? Number(order.total).toFixed(2) + ' ' + (order.currency || 'EUR') : '—'}

                                +readonlyField('Refunded to date')
                                    | #{orderRefundedTotal != null ? Number(orderRefundedTotal).toFixed(2) + ' ' + (order.currency || 'EUR') : '—'}

                                +readonlyField('Remaining refundable')
                                    | #{orderRemainingRefundable != null ? Number(orderRemainingRefundable).toFixed(2) + ' ' + (order.currency || 'EUR') : '—'}

                                //- Date (read-only)
                                +readonlyField('Date')
                                    | #{order.createdAt ? new Date(order.createdAt).toLocaleString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'}) : '—'}

                                +readonlyField('Order source')
                                    if order.source === 'event'
                                        span.da-badge.da-badge--info Event checkout
                                    else
                                        span Cart

                                +readonlyField('Stripe PaymentIntent')
                                    if order.stripePaymentIntentId
                                        span.da-cell-mono= order.stripePaymentIntentId
                                    else
                                        span.da-cell-muted —

                            .da-form-section
                                span.da-form-section-label Line items

                                if orderLines && orderLines.length
                                    .da-table-scroll(style='margin-top:0.5rem')
                                        table.da-table(role='table' aria-label='Order lines')
                                            thead
                                                tr
                                                    th(scope='col') Title
                                                    th(scope='col') Qty
                                                    th(scope='col') Unit price
                                                    th(scope='col') SKU
                                                    th(scope='col') Event
                                            tbody
                                                each line in orderLines
                                                    - var evId = line.eventId
                                                    tr
                                                        td= line.title || '—'
                                                        td= line.quantity != null ? line.quantity : '—'
                                                        td= line.price != null ? Number(line.price).toFixed(2) + ' ' + (order.currency || 'EUR') : '—'
                                                        td
                                                            span.da-cell-mono= line.sku || '—'
                                                        td
                                                            if evId
                                                                a.da-row-btn.da-row-btn--edit(
                                                                    href=(adminPrefix || '') + '/events/' + evId + '/registrants'
                                                                ) Registrants
                                                            else
                                                                span.da-cell-muted —
                                else
                                    p.da-refund-empty No line items for this order.

                            if transactions && transactions.length
                                .da-form-section
                                    span.da-form-section-label Payment transactions

                                    .da-table-scroll(style='margin-top:0.5rem')
                                        table.da-table(role='table' aria-label='Transactions')
                                            thead
                                                tr
                                                    th(scope='col') Status
                                                    th(scope='col') Amount
                                                    th(scope='col') Gateway reference
                                                    th.da-col-created(scope='col') Created
                                            tbody
                                                each tx in transactions
                                                    tr
                                                        td
                                                            if tx.status
                                                                span.da-badge(class='da-badge--' + ({success:'success',pending:'warning',failed:'danger',refunded:'info'})[tx.status] || 'neutral')= tx.status.charAt(0).toUpperCase() + tx.status.slice(1)
                                                            else
                                                                span —
                                                        td= tx.amount != null ? Number(tx.amount).toFixed(2) + ' ' + (tx.currency || order.currency || 'EUR') : '—'
                                                        td
                                                            span.da-cell-mono= tx.gatewayReference || '—'
                                                        td.da-col-created
                                                            span.da-cell-muted= tx.createdAt ? new Date(tx.createdAt).toLocaleString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'}) : '—'

                            //- Must not nest <form> inside #orderEditForm — use formaction so submit targets recovery routes (nested forms break and submit /edit without fulfillmentStatus).
                            if canRetryFinalize || canRetryPostCommit
                                .da-form-section
                                    span.da-form-section-label Checkout recovery
                                    p.da-form-hint(style='margin-bottom:0.75rem;max-width:36rem')
                                        | Use these if Stripe charged the customer but the order stayed pending, or if confirmation email or digital fulfillment failed after payment. For Zoom, use the event’s Registrants page and retry per registration.
                                    if canRetryFinalize
                                        button.da-btn.da-btn--secondary(
                                            type='submit'
                                            formaction=(adminPrefix || '') + '/orders/' + order.id + '/finalize-payment'
                                            formmethod='post'
                                            style='margin-right:0.5rem;margin-bottom:0.5rem'
                                        ) Finalize payment (inventory &amp; registrations)
                                    if canRetryPostCommit
                                        button.da-btn.da-btn--secondary(
                                            type='submit'
                                            formaction=(adminPrefix || '') + '/orders/' + order.id + '/retry-post-commit'
                                            formmethod='post'
                                            style='margin-bottom:0.5rem'
                                        ) Retry digital fulfillment

                            .da-form-section
                                span.da-form-section-label Fulfillment

                                //- Fulfillment status (editable)
                                .da-form-group
                                    label.da-form-label(for='fulfillmentStatus')
                                        | Fulfillment Status
                                        span.req *
                                    select#fulfillmentStatus.da-form-select(name='fulfillmentStatus' required)
                                        each s in validFulfillmentStatuses
                                            option(value=s selected=(order.fulfillmentStatus === s))= s.charAt(0).toUpperCase() + s.slice(1).replace(/_/g, ' ')

                            .da-form-section
                                span.da-form-section-label Addresses

                                //- Delivery address (read-only)
                                +readonlyField('Delivery Address')
                                    - var delivery = [order.deliveryLine1, order.deliveryLine2, [order.deliveryCity, order.deliveryState, order.deliveryPostcode].filter(Boolean).join(', '), order.deliveryCountry].filter(Boolean).join(' · ')
                                    | #{delivery || '—'}

                                //- Billing address (read-only)
                                +readonlyField('Billing Address')
                                    - var billing = [order.billingLine1, order.billingLine2, [order.billingCity, order.billingState, order.billingPostcode].filter(Boolean).join(', '), order.billingCountry].filter(Boolean).join(' · ')
                                    | #{billing || '—'}

                    .da-card-footer
                        button.da-btn.da-btn--primary(type='submit' form='orderEditForm') Save Changes
                        a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/orders') Back

            //- ── Aside: refund transactions + refund requests ─────────
            .da-form-aside

                .da-card
                    .da-card-header
                        h2.da-card-title Refund transactions
                        if refundTransactions && refundTransactions.length
                            span.da-count= refundTransactions.length + ' record' + (refundTransactions.length !== 1 ? 's' : '')
                    .da-card-body
                        if refundTransactions && refundTransactions.length
                            each rt in refundTransactions
                                - var rtStatusClass = ({pending:'warning',succeeded:'success',failed:'danger',cancelled:'neutral'})[rt.status] || 'neutral'
                                - var rtScopeLabel = ({full_order:'Full order',line_quantity:'Line quantity',event_attendee:'Event attendee'})[rt.scopeType] || (rt.scopeType || '—')
                                .da-refund-card
                                    .da-refund-card-header
                                        span.da-badge(class='da-badge--' + rtStatusClass)= rt.status ? rt.status.charAt(0).toUpperCase() + rt.status.slice(1) : '—'
                                    p.da-refund-meta
                                        strong Amount:&nbsp;
                                        | #{rt.amount != null ? Number(rt.amount).toFixed(2) : '—'} #{rt.currency || order.currency || 'EUR'}
                                    p.da-refund-meta
                                        strong Scope:&nbsp;
                                        | #{rtScopeLabel}
                                    if rt.reason
                                        p.da-refund-meta
                                            strong Reason:&nbsp;
                                            | #{rt.reason}
                                    if rt.stripeRefundId
                                        p.da-refund-meta
                                            strong Stripe refund:&nbsp;
                                            span.da-cell-mono= rt.stripeRefundId
                                    if rt.refundedQuantity != null
                                        p.da-refund-meta
                                            strong Quantity:&nbsp;
                                            | #{rt.refundedQuantity}
                                    if rt.registrationId
                                        p.da-refund-meta
                                            strong Registration:&nbsp;
                                            span.da-cell-mono= rt.registrationId.slice(0, 8) + '…'
                                    p.da-refund-meta
                                        strong Created:&nbsp;
                                        | #{rt.createdAt ? new Date(rt.createdAt).toLocaleString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'}) : '—'}
                                    if rt.processedAt
                                        p.da-refund-meta
                                            strong Processed:&nbsp;
                                            | #{new Date(rt.processedAt).toLocaleString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit'})}
                        else
                            p.da-refund-empty No refund transactions for this order.

                .da-card
                    .da-card-header
                        h2.da-card-title Refund Requests
                        if refundRequests && refundRequests.length
                            span.da-count= refundRequests.length + ' request' + (refundRequests.length !== 1 ? 's' : '')
                    .da-card-body
                        if refundRequests && refundRequests.length
                            if orderHasEventLines
                                - var approveConfirmMsg = 'Issue a Stripe refund for the remaining balance and complete this request. This order includes event lines: Zoom registrants are removed first, then Stripe refunds; registrations are cleared and inventory restored when the refund succeeds.'
                                - var approveConfirmBullets = JSON.stringify(['Remove Zoom access for online events (before Stripe)', 'Stripe refund for the remaining capture balance', 'Clear registrations and restore inventory when Stripe confirms'])
                            else
                                - var approveConfirmMsg = 'Issue a Stripe refund for the remaining balance and complete this request. Inventory and order records update when the refund succeeds.'
                                - var approveConfirmBullets = JSON.stringify(['Stripe refund for the remaining capture balance', 'Inventory and order updated when the refund completes'])
                            each r in refundRequests
                                - var rClass = ({pending:'warning',approved:'success',rejected:'danger'})[r.status] || 'neutral'
                                .da-refund-card
                                    .da-refund-card-header
                                        span.da-badge(class='da-badge--' + rClass)= r.status.charAt(0).toUpperCase() + r.status.slice(1)

                                    if r.reason
                                        p.da-refund-meta
                                            strong Reason:&nbsp;
                                            | #{r.reason}
                                    p.da-refund-meta
                                        strong Requested:&nbsp;
                                        | #{r.createdAt ? new Date(r.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'}
                                    if r.processedAt
                                        p.da-refund-meta
                                            strong Processed:&nbsp;
                                            | #{new Date(r.processedAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'})}
                                    if r.status === 'approved'
                                        p.da-refund-meta
                                            strong Amount:&nbsp;
                                            | #{order.total != null ? Number(order.total).toFixed(2) : '—'} #{order.currency || 'EUR'} (full refund)

                                    if r.status === 'pending'
                                        .da-refund-actions

                                            //- Approve
                                            - var approveFormId = 'approve-refund-form-' + r.id
                                            form(id=approveFormId method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/refund-request/' + r.id + '/approve')
                                                button.da-btn.da-btn--primary(
                                                    type='button'
                                                    data-confirm-modal
                                                    data-confirm-title='Approve Refund'
                                                    data-confirm-msg=approveConfirmMsg
                                                    data-confirm-bullets=approveConfirmBullets
                                                    data-form-id=approveFormId
                                                ) Approve

                                            //- Reject
                                            - var rejectFormId = 'reject-refund-form-' + r.id
                                            form(id=rejectFormId method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/refund-request/' + r.id + '/reject')
                                                button.da-btn.da-btn--danger(
                                                    type='button'
                                                    data-confirm-modal
                                                    data-confirm-title='Reject Refund Request'
                                                    data-confirm-msg='This will reject the refund request and return the order to delivered status.'
                                                    data-form-id=rejectFormId
                                                ) Reject
                        else
                            p.da-refund-empty No refund requests for this order.

                - var _refundCur = order.currency || 'EUR'
                - var _refundedSum = orderRefundedTotal != null ? Number(orderRefundedTotal) : 0
                - var _remainingSum = orderRemainingRefundable != null ? Number(orderRemainingRefundable) : 0
                .da-card
                    .da-card-header
                        h2.da-card-title Danger Zone
                    .da-card-body
                        if canCancelAndRefundOrder
                            p.da-refund-empty(style='margin-top:0')
                                | Refunds the <strong>remaining</strong> balance (
                                strong #{_remainingSum.toFixed(2)} #{_refundCur}
                                | ) after #{_refundedSum.toFixed(2)} #{_refundCur} already recorded as refunded.
                            - var cancelRefundFormId = 'admin-order-cancel-refund-form'
                            - var cancelRefundMsg = 'Cancel and refund ' + _remainingSum.toFixed(2) + ' ' + _refundCur + '? This cannot be undone.'
                            if orderHasEventLines
                                - var cancelRefundBullets = ['Remove Zoom access for online events (before Stripe)', 'Stripe refund for the remaining capture balance', 'Clear registrations and restore inventory when Stripe confirms']
                            else
                                - var cancelRefundBullets = ['Stripe refund for the remaining capture balance', 'Inventory and order updated when the refund completes']
                            div(style='display:flex;justify-content:center;margin:0;padding:0')
                                form(id=cancelRefundFormId method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/cancel-and-refund' style='display:none')
                                button.da-btn.da-btn--danger(
                                    type='button'
                                    data-confirm-modal
                                    data-confirm-title='Cancel & Refund Order'
                                    data-confirm-msg=cancelRefundMsg
                                    data-confirm-bullets=JSON.stringify(cancelRefundBullets)
                                    data-form-id=cancelRefundFormId
                                ) Cancel &amp; Refund Order
                        else if canFullRefund
                            p.da-refund-empty(style='margin-top:0')
                                | Order is eligible for a refund but cannot use this action (e.g. fulfillment already refunded or no remaining balance).
                        else
                            p.da-refund-empty(style='margin-top:0')
                                | No remaining balance to refund, or the order is not in a refundable payment state.
