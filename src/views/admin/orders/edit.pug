extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        .da-page-header
            .da-page-header-left
                h1.da-page-title Edit Order
                p.da-page-subtitle= order.id ? '#' + order.id.slice(0, 8) + '…' : 'Order details'
            .da-page-header-right
                a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/orders')
                    svg(xmlns='http://www.w3.org/2000/svg' width='13' height='13' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        polyline(points='15 18 9 12 15 6')
                    | Back to Orders

        if error
            p.admin-flash.admin-flash-error= error

        //- ── Two-column grid: form main + refund aside ───────────────
        .da-form-grid

            //- ── Main column: order details ──────────────────────────
            .da-form-main

                .da-card
                    .da-card-header
                        h2.da-card-title Order Details
                    .da-card-body
                        form#orderEditForm(
                            method='post'
                            action=(adminPrefix || '') + '/orders/' + order.id + '/edit'
                        )
                            .da-form-section
                                span.da-form-section-label Identity

                                //- Order ID (read-only)
                                .da-readonly-group
                                    span.da-readonly-label Order ID
                                    .da-readonly-value
                                        span.da-cell-mono= order.id || '—'

                                //- Customer (read-only)
                                .da-readonly-group
                                    span.da-readonly-label Customer
                                    .da-readonly-value= order.email || (order.forename || order.surname ? (order.forename || '') + ' ' + (order.surname || '') : order.userId ? 'User #' + order.userId : 'Guest') || '—'

                                //- Person type
                                .da-readonly-group
                                    span.da-readonly-label Person Type
                                    .da-readonly-value
                                        if order.personType === 'legal'
                                            span.da-badge.da-badge--info Legal person
                                        else
                                            span Private person

                                //- Company info (legal persons only)
                                if order.personType === 'legal'
                                    .da-readonly-group
                                        span.da-readonly-label Company Name
                                        .da-readonly-value= order.companyName || '—'
                                    .da-readonly-group
                                        span.da-readonly-label OIB
                                        .da-readonly-value= order.companyOib || '—'

                                //- Payment status (read-only with badge)
                                .da-readonly-group
                                    span.da-readonly-label Payment Status
                                    .da-readonly-value
                                        - var payClass = ({paid:'success',pending:'warning',failed:'danger',refunded:'info',cancelled:'neutral'})[order.paymentStatus] || 'neutral'
                                        if order.paymentStatus
                                            span.da-badge(class='da-badge--' + payClass)= order.paymentStatus.charAt(0).toUpperCase() + order.paymentStatus.slice(1)
                                        else
                                            span —

                                //- Total (read-only)
                                .da-readonly-group
                                    span.da-readonly-label Total
                                    .da-readonly-value= order.total != null ? Number(order.total).toFixed(2) + ' ' + (order.currency || 'EUR') : '—'

                                //- Date (read-only)
                                .da-readonly-group
                                    span.da-readonly-label Date
                                    .da-readonly-value= order.createdAt ? new Date(order.createdAt).toLocaleString('en-US', {month:'short', day:'numeric', year:'numeric', hour:'2-digit', minute:'2-digit'}) : '—'

                            .da-form-section
                                span.da-form-section-label Fulfillment

                                //- Fulfillment status (editable)
                                .da-form-group
                                    label.da-form-label(for='fulfillmentStatus')
                                        | Fulfillment Status
                                        span.req *
                                    select#fulfillmentStatus.da-form-select(name='fulfillmentStatus' required)
                                        each s in validFulfillmentStatuses
                                            option(value=s selected=(order.fulfillmentStatus === s))= s.charAt(0).toUpperCase() + s.slice(1).replace(/_/g, ' ')

                            .da-form-section
                                span.da-form-section-label Addresses

                                //- Delivery address (read-only)
                                .da-readonly-group
                                    span.da-readonly-label Delivery Address
                                    .da-readonly-value
                                        - var delivery = [order.deliveryLine1, order.deliveryLine2, [order.deliveryCity, order.deliveryState, order.deliveryPostcode].filter(Boolean).join(', '), order.deliveryCountry].filter(Boolean).join(' · ')
                                        | #{delivery || '—'}

                                //- Billing address (read-only)
                                .da-readonly-group
                                    span.da-readonly-label Billing Address
                                    .da-readonly-value
                                        - var billing = [order.billingLine1, order.billingLine2, [order.billingCity, order.billingState, order.billingPostcode].filter(Boolean).join(', '), order.billingCountry].filter(Boolean).join(' · ')
                                        | #{billing || '—'}

                    .da-card-footer
                        button.da-btn.da-btn--primary(type='submit' form='orderEditForm') Save Changes
                        a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/orders') Cancel

            //- ── Aside: refund requests ──────────────────────────────
            .da-form-aside

                .da-card
                    .da-card-header
                        h2.da-card-title Refund Requests
                        if refundRequests && refundRequests.length
                            span.da-count= refundRequests.length + ' request' + (refundRequests.length !== 1 ? 's' : '')
                    .da-card-body
                        if refundRequests && refundRequests.length
                            each r in refundRequests
                                - var rClass = ({pending:'warning',approved:'success',rejected:'danger'})[r.status] || 'neutral'
                                .da-refund-card
                                    .da-refund-card-header
                                        span.da-badge(class='da-badge--' + rClass)= r.status.charAt(0).toUpperCase() + r.status.slice(1)

                                    if r.reason
                                        p.da-refund-meta
                                            strong Reason:&nbsp;
                                            | #{r.reason}
                                    p.da-refund-meta
                                        strong Requested:&nbsp;
                                        | #{r.createdAt ? new Date(r.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) : '—'}
                                    if r.processedAt
                                        p.da-refund-meta
                                            strong Processed:&nbsp;
                                            | #{new Date(r.processedAt).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'})}
                                    if r.status === 'approved'
                                        p.da-refund-meta
                                            strong Amount:&nbsp;
                                            | #{order.total != null ? Number(order.total).toFixed(2) : '—'} #{order.currency || 'EUR'} (full refund)

                                    if r.status === 'pending'
                                        .da-refund-actions

                                            //- Approve
                                            form(method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/refund-request/' + r.id + '/approve')
                                                button.da-btn.da-btn--primary(type='submit') Approve

                                            //- Reject
                                            form(method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/refund-request/' + r.id + '/reject')
                                                button.da-btn.da-btn--danger(type='submit') Reject
                        else
                            p.da-refund-empty No refund requests for this order.

                //- ── Invoice ─────────────────────────────────────────
                .da-card(style='margin-top:1rem')
                    .da-card-header
                        h2.da-card-title Invoice
                    .da-card-body
                        if invoice
                            .da-detail-list
                                .da-detail-item
                                    span.da-detail-label Number
                                    span.da-detail-line.da-cell-mono= invoice.invoiceNumber
                                .da-detail-item
                                    span.da-detail-label Type
                                    span.da-detail-line
                                        if invoice.type === 'r1'
                                            span.da-badge.da-badge--info R1 Račun
                                        else
                                            span.da-badge.da-badge--neutral Receipt
                                .da-detail-item
                                    span.da-detail-label Status
                                    span.da-detail-line
                                        - var iClass = invoice.status === 'issued' ? 'success' : 'danger'
                                        span.da-badge(class='da-badge--' + iClass)= invoice.status.charAt(0).toUpperCase() + invoice.status.slice(1)
                                .da-detail-item
                                    span.da-detail-label Issued
                                    span.da-detail-line= invoice.generatedAt ? new Date(invoice.generatedAt).toLocaleDateString('hr-HR', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'

                            //- ── Storno invoice (shown when refund was processed) ──
                            if stornoInvoice
                                hr(style='margin:1rem 0;border-color:var(--ds-border)')
                                p(style='font-size:0.75rem;color:var(--ds-text-3);margin-bottom:0.5rem') Storno račun
                                .da-detail-list
                                    .da-detail-item
                                        span.da-detail-label Number
                                        span.da-detail-line.da-cell-mono= stornoInvoice.invoiceNumber
                                    .da-detail-item
                                        span.da-detail-label Fiscalisation
                                        span.da-detail-line
                                            - var sfClass = stornoInvoice.fiscalizationStatus === 'fiscalized' ? 'success' : stornoInvoice.fiscalizationStatus === 'failed' ? 'danger' : stornoInvoice.fiscalizationStatus === 'not_required' ? 'neutral' : 'warning'
                                            - var sfLabel = stornoInvoice.fiscalizationStatus === 'fiscalized' ? 'Fiscalised' : stornoInvoice.fiscalizationStatus === 'failed' ? 'Failed' : stornoInvoice.fiscalizationStatus === 'not_required' ? 'N/A' : 'Pending'
                                            span.da-badge(class='da-badge--' + sfClass)= sfLabel
                                    if stornoInvoice.fiscalizationJir
                                        .da-detail-item
                                            span.da-detail-label JIR
                                            span.da-detail-line(style='font-family:monospace;font-size:0.72rem')= stornoInvoice.fiscalizationJir
                                    .da-detail-item
                                        span.da-detail-label Issued
                                        span.da-detail-line= stornoInvoice.generatedAt ? new Date(stornoInvoice.generatedAt).toLocaleDateString('hr-HR', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'
                                if stornoInvoice.fiscalizationStatus === 'pending' || stornoInvoice.fiscalizationStatus === 'failed'
                                    form(method='post' action=(adminPrefix || '') + '/invoices/' + stornoInvoice.id + '/fiscalize' style='margin-top:0.75rem')
                                        button.da-btn.da-btn--secondary(type='submit') Retry Fiscalisation
                        else
                            if order.paymentStatus === 'paid'
                                p.da-refund-empty Invoice not generated.
                                form(method='post' action=(adminPrefix || '') + '/orders/' + order.id + '/regenerate-invoice' style='margin-top:0.75rem')
                                    button.da-btn.da-btn--secondary(type='submit') Generate Invoice
                            else
                                p.da-refund-empty Invoice will be created when the order is paid.
