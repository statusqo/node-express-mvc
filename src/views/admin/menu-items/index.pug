extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        - var menuItemsSubtitle = selectedMenu ? selectedMenu.name + ' (' + selectedMenu.slug + ')' : 'Select a menu to edit its items'
        +pageHeader('Menu Items', menuItemsSubtitle)
            if selectedMenu
                +addBtn((adminPrefix || '') + '/menu-items/new?menu=' + selectedMenu.slug, 'Add Item')

        //- ── Menu selector ───────────────────────────────────────────
        if menusList && menusList.length
            form.da-filter-bar(method='get' action=(adminPrefix || '') + '/menu-items')
                .da-filter-head
                    span.da-filter-head-label Active Menu
                .da-form-group(style='margin:0; flex:1; min-width:200px; max-width:420px;')
                    select#menu-select.da-form-select(
                        name='menu'
                        onchange='this.form.submit()'
                    )
                        each m in menusList
                            option(value=m.slug selected=(selectedMenu && selectedMenu.slug === m.slug))= m.name + ' (' + m.slug + ')'
        else
            p.admin-flash.admin-flash-info No menus yet.&nbsp;
                a(href=(adminPrefix || '') + '/menus/new') Create a menu first.

        if selectedMenu
            //- ── Items table ─────────────────────────────────────────
            .da-section
                .da-section-header
                    h2.da-section-title Items
                    span.da-count= items ? items.length : 0

                .da-panel
                    .da-table-scroll
                        table.da-table(role='table' aria-label='Menu items list')
                            thead
                                tr
                                    th(scope='col') Label
                                    th(scope='col') URL
                                    th(scope='col') Order
                                    th(scope='col') Icon
                                    th(scope='col') Slug
                                    th(scope='col') Method
                                    th(scope='col') Status
                                    th(scope='col' style='text-align:right') Actions
                            tbody
                                if items && items.length
                                    each item in items
                                        tr.da-row(data-item-id=item.id)
                                            td(style=item.depth > 0 ? 'padding-left: ' + (item.depth * 24 + 12) + 'px;' : '')
                                                span.da-cell-primary= item.label
                                            td
                                                span.da-cell-muted= item.url
                                            td
                                                span.da-cell-muted= item.order
                                            td= item.icon || '—'
                                            td
                                                if item.slug
                                                    span.da-cell-mono= item.slug
                                                else
                                                    | —
                                            td
                                                span.da-cell-mono= item.method || 'GET'
                                            td
                                                if item.active
                                                    span.da-badge.da-badge--success Active
                                                else
                                                    span.da-badge.da-badge--neutral Inactive
                                            td
                                                .da-cell-actions
                                                    a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/menu-items/' + item.id + '/edit' aria-label='Edit ' + item.label) Edit
                                else
                                    +tableEmpty('No items in this menu yet.', 8)

