extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        .da-page-header
            .da-page-header-left
                h1.da-page-title Meta Objects
                p.da-page-subtitle= (metaObjects ? metaObjects.length : 0) + ' object' + ((metaObjects && metaObjects.length !== 1) ? 's' : '')

            .da-page-header-right
                a.da-btn.da-btn--primary(href=(adminPrefix || '') + '/meta-objects/new')
                    svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        line(x1='12' y1='5' x2='12' y2='19')
                        line(x1='5' y1='12' x2='19' y2='12')
                    | Add Meta Object

        //- ── Meta Objects table ───────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title All meta objects
                span.da-count= metaObjects ? metaObjects.length : 0

            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Meta objects list')
                        thead
                            tr
                                th(scope='col') Name
                                th(scope='col') Slug
                                th(scope='col') Type
                                th(scope='col') Status
                                th(scope='col' style='text-align:right') Actions
                        tbody
                            if metaObjects && metaObjects.length
                                each mo in metaObjects
                                    tr.da-row(data-meta-object-id=mo.id)
                                        td
                                            span.da-cell-primary= mo.name
                                        td
                                            span.da-cell-mono= mo.slug || '—'
                                        td
                                            span.da-cell-secondary= mo.type || '—'
                                        td
                                            if mo.active
                                                span.da-badge.da-badge--success Active
                                            else
                                                span.da-badge.da-badge--neutral Inactive
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/meta-objects/' + mo.id + '/edit' aria-label='Edit ' + mo.name) Edit
                                                .da-delete-wrap(aria-label='Delete meta object actions')
                                                    button.da-row-btn.da-row-btn--delete.da-delete-trigger(
                                                        type='button'
                                                        aria-label='Delete ' + mo.name
                                                        aria-expanded='false'
                                                    ) Delete
                                                    .da-confirm-group(role='group' aria-label='Confirm deletion')
                                                        button.da-row-btn.da-row-btn--cancel.da-delete-cancel(
                                                            type='button'
                                                            aria-label='Cancel deletion'
                                                        ) No
                                                        span.da-confirm-sep(aria-hidden='true')
                                                        form.da-form-inline.da-delete-form(
                                                            method='post'
                                                            action=(adminPrefix || '') + '/meta-objects/' + mo.id + '/delete'
                                                        )
                                                            button.da-row-btn.da-row-btn--confirm(
                                                                type='submit'
                                                                aria-label='Confirm delete ' + mo.name
                                                            ) Yes, delete
                            else
                                tr
                                    td(colspan='5')
                                        .da-table-empty No meta objects yet.
