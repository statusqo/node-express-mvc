extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader('Meta Objects', (metaObjects ? metaObjects.length : 0) + ' object' + ((metaObjects && metaObjects.length !== 1) ? 's' : ''))
            +addBtn((adminPrefix || '') + '/meta-objects/new', 'Add Meta Object')

        //- ── Meta Objects table ───────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title All meta objects
                span.da-count= metaObjects ? metaObjects.length : 0

            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Meta objects list')
                        thead
                            tr
                                th(scope='col') Name
                                th(scope='col') Slug
                                th(scope='col') Type
                                th(scope='col') Status
                                th(scope='col' style='text-align:right') Actions
                        tbody
                            if metaObjects && metaObjects.length
                                each mo in metaObjects
                                    tr.da-row(data-meta-object-id=mo.id)
                                        td
                                            span.da-cell-primary= mo.name
                                        td
                                            span.da-cell-mono= mo.slug || '—'
                                        td
                                            span.da-cell-secondary= mo.type || '—'
                                        td
                                            if mo.active
                                                span.da-badge.da-badge--success Active
                                            else
                                                span.da-badge.da-badge--neutral Inactive
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/meta-objects/' + mo.id + '/edit' aria-label='Edit ' + mo.name) Edit
                            else
                                +tableEmpty('No meta objects yet.', 5)
