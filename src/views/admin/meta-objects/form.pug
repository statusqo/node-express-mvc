extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        .da-page-header
            .da-page-header-left
                h1.da-page-title= isEdit ? 'Edit Meta Object' : 'New Meta Object'
                p.da-page-subtitle= isEdit && metaObject && metaObject.name ? metaObject.name : 'Define a meta object and its attributes'
            .da-page-header-right
                a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/meta-objects')
                    svg(xmlns='http://www.w3.org/2000/svg' width='13' height='13' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        polyline(points='15 18 9 12 15 6')
                    | Back to Meta Objects

        if errors && errors.length
            .admin-flash.admin-flash-error
                ul(style='margin: 0; padding-left: 1.25rem;')
                    each e in errors
                        - var pathStr = Array.isArray(e.path) ? e.path.join('.') : (e.path || '')
                        li= pathStr ? pathStr + ': ' + (e.message || 'invalid') : (e.message || 'invalid')

        //- ── Form ─────────────────────────────────────────────────────
        .da-card(style='max-width: 720px;')
            form#metaObjectForm(method='post' action=isEdit ? (adminPrefix || '') + '/meta-objects/' + metaObject.id + '/edit' : (adminPrefix || '') + '/meta-objects/new')
                .da-card-body
                    .da-form-section
                        h2.da-form-section-label Details
                        .da-form-group
                            label.da-form-label(for='name')
                                | Name
                                span.req *
                            input#name.da-form-input(
                                type='text'
                                name='name'
                                required
                                value=metaObject ? metaObject.name : ''
                                placeholder='Meta object name'
                                autofocus
                            )
                        .da-form-group
                            label.da-form-label(for='slug') Slug
                            input#slug.da-form-input(
                                type='text'
                                name='slug'
                                value=metaObject ? metaObject.slug : ''
                                placeholder='Auto-generated from name if left blank'
                            )
                            p.da-form-hint Lowercase letters, numbers, and hyphens only.
                        .da-form-group
                            label.da-form-label(for='type') Type
                            input#type.da-form-input(
                                type='text'
                                name='type'
                                value=metaObject ? metaObject.type : ''
                                placeholder='e.g. certificate, warranty'
                            )

                    .da-form-section
                        h2.da-form-section-label Attribute definition
                        .da-form-group
                            p.da-form-hint(style='margin-bottom: 0.75rem;') Values are set per product when linking a meta object to a product.
                            //- admin-table-card.admin-definition-card: kept for definition editor; styled in admin-dark.css
                            .admin-table-card.admin-definition-card
                                .admin-definition-header
                                    span.admin-definition-header-cell.admin-definition-cell-key Key
                                    span.admin-definition-header-cell.admin-definition-cell-type Type
                                    span.admin-definition-header-cell.admin-definition-cell-actions Actions
                                #definitionPairs.admin-definition-pairs
                                    each pair, i in (definitionPairs || [])
                                        .definition-row(data-index=i)
                                            input.definition-key(type='text' placeholder='Key' value=pair.key)
                                            select.definition-type
                                                option(value='string' selected=(pair.type === 'string')) String
                                                option(value='text' selected=(pair.type === 'text')) Text
                                                option(value='number' selected=(pair.type === 'number')) Number
                                                option(value='date' selected=(pair.type === 'date')) Date
                                                option(value='url' selected=(pair.type === 'url')) URL
                                                option(value='email' selected=(pair.type === 'email')) Email
                                                option(value='boolean' selected=(pair.type === 'boolean')) Boolean
                                            .admin-definition-cell-actions
                                                .da-delete-wrap(aria-label='Remove attribute')
                                                    button.da-row-btn.da-row-btn--delete.da-definition-remove-trigger(type='button' aria-label='Remove attribute' aria-expanded='false') Remove
                                                    .da-confirm-group(role='group' aria-label='Confirm removal')
                                                        button.da-row-btn.da-row-btn--cancel.da-definition-remove-cancel(type='button' aria-label='Cancel') No
                                                        span.da-confirm-sep(aria-hidden='true')
                                                        button.da-row-btn.da-row-btn--confirm.da-definition-remove-confirm(type='button' aria-label='Yes, remove') Yes, remove
                                .admin-definition-footer
                                    button.da-btn.da-btn--secondary#addDefinitionPair(type='button') Add attribute
                            input#definition(type='hidden' name='definition' value='')

                    .da-form-section
                        h2.da-form-section-label Visibility
                        .da-form-group
                            label.admin-checkbox
                                input(type='checkbox' name='active' value='on' checked=(metaObject === null || metaObject.active))
                                | Active

                .da-card-footer
                    button.da-btn.da-btn--primary(type='submit')= isEdit ? 'Update' : 'Create'
                    a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/meta-objects') Cancel

block append scripts
    script(src='/public/js/admin-meta-object-form.js')
