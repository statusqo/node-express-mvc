extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Sticky page header ───────────────────────────────────────
        .da-page-header.da-page-header--sticky
            .da-page-header-left
                h1.da-page-title= product.title
                p.da-page-subtitle
                    span.da-cell-mono= product.slug
                    | &ensp;·&ensp;Default:&ensp;
                    | #{product.priceAmount != null ? (product.currency || 'USD') + ' ' + product.priceAmount : '—'}
            .da-page-header-right
                a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/' + sectionPath)
                    svg(xmlns='http://www.w3.org/2000/svg' width='13' height='13' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        polyline(points='15 18 9 12 15 6')
                    | Back to #{typeLabel}s

        if flash && flash.message
            p.admin-flash(class='admin-flash-' + (flash.type || 'info'))= flash.message
        if error
            p.admin-flash.admin-flash-error= error

        //- ── Toolbar ──────────────────────────────────────────────────
        .da-events-toolbar
            .da-events-toolbar-left
                if zoomConnected
                    form#sync-zoom-form(method='post' action=(adminPrefix || '') + '/' + sectionPath + '/' + product.slug + '/events/sync-zoom')
                        button.da-btn.da-btn--secondary(type='submit')
                            svg(xmlns='http://www.w3.org/2000/svg' width='13' height='13' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                                polyline(points='1 4 1 10 7 10')
                                path(d='M3.51 15a9 9 0 1 0 .49-4.95L1 10')
                            | Sync With Zoom
                else
                    button.da-btn.da-btn--secondary(type='button' disabled title='Connect a Zoom account first')
                        svg(xmlns='http://www.w3.org/2000/svg' width='13' height='13' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                            polyline(points='1 4 1 10 7 10')
                            path(d='M3.51 15a9 9 0 1 0 .49-4.95L1 10')
                        | Sync With Zoom

            .da-events-toolbar-right
                a.da-btn.da-btn--primary(href=(adminPrefix || '') + '/' + sectionPath + '/' + product.slug + '/events/new')
                    svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        line(x1='12' y1='5' x2='12' y2='19')
                        line(x1='5' y1='12' x2='19' y2='12')
                    | Add Event

        //- ── Empty state ──────────────────────────────────────────────
        .da-events-empty#no-events-message(style=(events && events.length > 0 ? 'display:none' : ''))
            svg(xmlns='http://www.w3.org/2000/svg' width='22' height='22' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                rect(x='3' y='4' width='18' height='18' rx='2' ry='2')
                line(x1='16' y1='2' x2='16' y2='6')
                line(x1='8' y1='2' x2='8' y2='6')
                line(x1='3' y1='10' x2='21' y2='10')
            span
                | No events yet.&ensp;
                a(href=(adminPrefix || '') + '/' + sectionPath + '/' + product.slug + '/events/new') Add Event
                | &nbsp;to create one.

        //- ── Events table (display only) ───────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title Events
                span.da-count= events ? events.length : 0
            .da-panel#events-table-wrap(style=(events && events.length > 0 ? '' : 'display:none'))
                .da-table-scroll
                    table.da-table.da-table--events(role='table' aria-label='Events')
                        thead
                            tr
                                th(scope='col') Date
                                th(scope='col') Time
                                th(scope='col') Dur.
                                th(scope='col') Location
                                th(scope='col') Cap.
                                th(scope='col') Seats
                                th(scope='col') Online
                                th(scope='col' title='Zoom meeting status') Mtg
                                th(scope='col') Status
                                th(scope='col') TZ
                                th(scope='col') Price
                                th(scope='col') Curr.
                                th(scope='col' style='text-align:right') Actions

                        tbody#events-tbody
                            - function formatDDMMYY(s) { if (!s) return '—'; var d = new Date(s); if (isNaN(d.getTime())) return String(s); var day = ('0' + d.getDate()).slice(-2); var month = ('0' + (d.getMonth() + 1)).slice(-2); var year = String(d.getFullYear()).slice(-2); return day + '-' + month + '-' + year; }
                            each ev in events
                                - var evStatusClass = ({active:'da-badge--success', cancelled:'da-badge--danger', orphaned:'da-badge--warning'})[ev.eventStatus] || 'da-badge--neutral'
                                - var cancelMsg = ev.registrationCount > 0 ? 'Cancel this event? ' + ev.registrationCount + ' registrant(s) will be removed from Zoom, orders refunded, and attendees notified. Event will be marked cancelled.' : 'Cancel this event? It will be marked cancelled.'
                                - var orphanCancelMsg = ev.registrationCount > 0 ? 'Cancel this orphaned event? ' + ev.registrationCount + ' registration(s) will be removed, orders refunded, and attendees notified.' : 'Cancel this orphaned event? It will be marked cancelled.'
                                tr.event-row.da-row(data-event-id=ev.id data-event-status=ev.eventStatus || 'active')
                                    td
                                        span.da-cell-muted= formatDDMMYY(ev.startDate)
                                    td
                                        span.da-cell-muted= ev.startTime ? String(ev.startTime).substring(0, 5) : '—'
                                    td
                                        span.da-cell-secondary= ev.durationMinutes != null ? ev.durationMinutes + ' min' : '—'
                                    td
                                        span.da-cell-secondary= ev.location || '—'
                                    td
                                        span.da-cell-secondary= ev.capacity != null ? ev.capacity : '—'
                                    td
                                        span.da-cell-secondary= ev.seatsRemaining != null ? ev.seatsRemaining : '—'
                                    td
                                        if ev.isOnline
                                            span.da-badge.da-badge--info Online
                                        else
                                            span.da-badge.da-badge--neutral Offline
                                    td
                                        if ev.meetingLinkStatus === 'synced'
                                            span.da-sync-badge.da-sync-badge--synced(title='Meeting created on Zoom') ✓
                                        else if ev.meetingLinkStatus === 'not_synced'
                                            - var nsTitle = ev.eventStatus === 'orphaned' ? 'Zoom meeting was deleted — re-sync or cancel this event' : 'No Zoom meeting yet'
                                            span.da-sync-badge.da-sync-badge--not-synced(title=nsTitle) —
                                        else
                                            span.da-cell-muted —
                                    td
                                        span.da-badge(class=evStatusClass)= (ev.eventStatus || 'active').charAt(0).toUpperCase() + (ev.eventStatus || 'active').slice(1)
                                    td
                                        span.da-cell-muted= ev.timezone || '—'
                                    td
                                        span.da-cell-secondary= ev.priceAmount != null ? ev.priceAmount : '—'
                                    td
                                        span.da-cell-muted= ev.currency || 'USD'
                                    td
                                        .da-cell-actions
                                            if ev.eventStatus === 'orphaned'
                                                button.da-row-btn.da-row-btn--resync.event-action-resync(
                                                    type='button'
                                                    data-event-id=ev.id
                                                ) Re-sync
                                                button.da-row-btn.da-row-btn--delete.event-action-cancel(
                                                    type='button'
                                                    data-event-id=ev.id
                                                    data-confirm-msg=orphanCancelMsg
                                                ) Cancel
                                            else if ev.eventStatus === 'active'
                                                button.da-row-btn.da-row-btn--delete.event-action-cancel(
                                                    type='button'
                                                    data-event-id=ev.id
                                                    data-confirm-msg=cancelMsg
                                                ) Cancel
                                            else if ev.eventStatus === 'cancelled'
                                                .da-delete-wrap(aria-label='Remove event actions')
                                                    button.da-row-btn.da-row-btn--delete.da-delete-trigger(
                                                        type='button'
                                                        aria-label='Remove cancelled event'
                                                        aria-expanded='false'
                                                    ) Remove
                                                    .da-confirm-group(role='group' aria-label='Confirm removal')
                                                        button.da-row-btn.da-row-btn--cancel.da-delete-cancel(
                                                            type='button'
                                                            aria-label='Cancel removal'
                                                        ) No
                                                        span.da-confirm-sep(aria-hidden='true')
                                                        form.da-form-inline.da-delete-form(
                                                            method='post'
                                                            action=(adminPrefix || '') + '/' + sectionPath + '/' + product.slug + '/events/remove-event'
                                                        )
                                                            input(type='hidden' name='eventId' value=ev.id)
                                                            button.da-row-btn.da-row-btn--confirm(
                                                                type='submit'
                                                                aria-label='Confirm remove event'
                                                            ) Yes, remove

        span#events-action-urls(
            data-base-url=(adminPrefix || '') + '/' + sectionPath + '/' + product.slug + '/events'
            style='display:none'
        )

block append scripts
    script.
        (function () {
            'use strict';

            /* ── Delete confirmation flow (same as Users / Collections) ───────── */
            function initDeleteFlow() {
                document.querySelectorAll('.da-delete-trigger').forEach(function (trigger) {
                    trigger.addEventListener('click', function () {
                        var row = trigger.closest('tr.da-row');
                        if (!row) return;
                        row.classList.add('da-row--confirming');
                        trigger.setAttribute('aria-expanded', 'true');
                        var cancel = row.querySelector('.da-delete-cancel');
                        if (cancel) setTimeout(function () { cancel.focus(); }, 200);
                    });
                });

                document.querySelectorAll('.da-delete-cancel').forEach(function (cancel) {
                    cancel.addEventListener('click', function () {
                        var row = cancel.closest('tr.da-row');
                        if (!row) return;
                        row.classList.remove('da-row--confirming');
                        var trigger = row.querySelector('.da-delete-trigger');
                        if (trigger) {
                            trigger.setAttribute('aria-expanded', 'false');
                            setTimeout(function () { trigger.focus(); }, 200);
                        }
                    });
                });

                document.querySelectorAll('.da-delete-form').forEach(function (form) {
                    form.addEventListener('submit', function (e) {
                        e.preventDefault();
                        var row = form.closest('tr');
                        if (!row) { form.submit(); return; }
                        row.classList.add('da-row--removing');
                        setTimeout(function () { form.submit(); }, 340);
                    });
                });
            }

            document.addEventListener('keydown', function (e) {
                if (e.key !== 'Escape') return;
                document.querySelectorAll('tr.da-row.da-row--confirming').forEach(function (row) {
                    row.classList.remove('da-row--confirming');
                    var trigger = row.querySelector('.da-delete-trigger');
                    if (trigger) trigger.setAttribute('aria-expanded', 'false');
                });
            });

            /* ── Cancel / Re-sync via POST ───────────────────────────── */
            var actionUrls = document.getElementById('events-action-urls');
            var baseUrl = actionUrls ? actionUrls.getAttribute('data-base-url') || '' : '';

            function postEventAction(actionPath, eventId, extraFields) {
                if (!baseUrl || !eventId) return;
                var f = document.createElement('form');
                f.method = 'post';
                f.action = baseUrl + actionPath;
                var inp = document.createElement('input');
                inp.type = 'hidden';
                inp.name = 'eventId';
                inp.value = eventId;
                f.appendChild(inp);
                if (extraFields) {
                    for (var k in extraFields) {
                        var i = document.createElement('input');
                        i.type = 'hidden';
                        i.name = k;
                        i.value = extraFields[k];
                        f.appendChild(i);
                    }
                }
                document.body.appendChild(f);
                f.submit();
            }

            document.addEventListener('click', function (e) {
                var btn = e.target;
                if (btn.classList.contains('event-action-resync')) {
                    e.preventDefault();
                    var eventId = btn.getAttribute('data-event-id');
                    if (eventId) postEventAction('/resync-event', eventId);
                } else if (btn.classList.contains('event-action-cancel')) {
                    e.preventDefault();
                    var eventId = btn.getAttribute('data-event-id');
                    var msg = btn.getAttribute('data-confirm-msg') || 'Cancel this event?';
                    if (eventId && confirm(msg)) postEventAction('/cancel-event', eventId, { confirm: '1' });
                }
            });

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initDeleteFlow);
            } else {
                initDeleteFlow();
            }
        })();
