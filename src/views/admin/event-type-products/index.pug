extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        if flash && flash.message
            p.admin-flash(class='admin-flash-' + (flash.type || 'info'))= flash.message

        //- ── Page header ─────────────────────────────────────────────
        .da-page-header
            .da-page-header-left
                h1.da-page-title= typeLabel ? typeLabel + 's' : 'Event Products'
                p.da-page-subtitle= (products ? products.length : 0) + ' product' + ((products && products.length !== 1) ? 's' : '')

        p.da-events-type-hint
            | Products are managed under&nbsp;
            a.da-events-type-hint-link(href=(adminPrefix || '') + '/products') Products
            | . Set product type to&nbsp;
            strong= typeLabel
            | &nbsp;to have them appear here.

        //- ── Products table ───────────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title= typeLabel ? typeLabel + ' products' : 'Event products'
                span.da-count= products ? products.length : 0
            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label=(typeLabel ? typeLabel + 's' : 'Event products') + ' list')
                        thead
                            tr
                                th(scope='col') Title
                                th.da-col-slug(scope='col') Slug
                                th.da-col-price(scope='col') Default Price
                                th(scope='col' style='text-align:right') Actions
                        tbody
                            if products && products.length
                                each p in products
                                    tr
                                        td
                                            span.da-cell-primary= p.title
                                        td.da-col-slug
                                            span.da-cell-mono= p.slug || '—'
                                        td.da-col-price
                                            span.da-cell-secondary= p.priceAmount != null ? (p.currency || 'USD') + ' ' + Number(p.priceAmount).toFixed(2) : '—'
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(
                                                    href=(adminPrefix || '') + '/' + sectionPath + '/' + p.slug + '/events'
                                                    aria-label='Manage events for ' + p.title
                                                ) Events
                            else
                                tr
                                    td(colspan='4')
                                        .da-table-empty
                                            svg(xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true' style='color:var(--ds-text-3)')
                                                rect(x='3' y='4' width='18' height='18' rx='2' ry='2')
                                                line(x1='16' y1='2' x2='16' y2='6')
                                                line(x1='8' y1='2' x2='8' y2='6')
                                                line(x1='3' y1='10' x2='21' y2='10')
                                            span No #{typeLabel} products yet.
