extends ../../layouts/admin
include ../../fragments/admin/media-picker-section
include ../../fragments/admin/meta-object-picker-section

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader(isEdit ? 'Edit Product' : 'New Product', isEdit && product && product.title ? product.title : 'Fill in the product details below')
            +backBtn((adminPrefix || '') + '/products', 'Back to Products')

        +formError(error)

        //- ── Product form (single stacked-card layout) ────────────────
        form#productForm(
            method='post'
            action=isEdit ? (adminPrefix || '') + '/products/' + product.id + '/edit' : (adminPrefix || '') + '/products/new'
        )
            .da-product-form-layout

                //- ── Details ─────────────────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Details
                    .da-card-body
                        .da-form-section
                            span.da-form-section-label Identity
                            .da-form-group
                                label.da-form-label(for='title')
                                    | Title
                                    span.req *
                                input#title.da-form-input(
                                    type='text'
                                    name='title'
                                    required
                                    value=product ? product.title : ''
                                    placeholder='Product title'
                                )
                            .da-form-group
                                label.da-form-label(for='slug') Slug
                                input#slug.da-form-input(
                                    type='text'
                                    name='slug'
                                    value=product ? product.slug : ''
                                    placeholder='Auto-generated from title if left blank'
                                )
                            .da-form-group
                                label.da-form-label(for='description') Description
                                textarea#description.da-form-input(
                                    name='description'
                                    rows='4'
                                    placeholder='Optional description'
                                )= product ? product.description : ''

                //- ── Pricing ─────────────────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Pricing
                    .da-card-body
                        .da-form-row
                            .da-form-group
                                label.da-form-label(for='priceAmount') Default price
                                input#priceAmount.da-form-input(
                                    type='number'
                                    name='priceAmount'
                                    step='0.01'
                                    min='0'
                                    value=product && product.priceAmount != null ? product.priceAmount : ''
                                    placeholder='0.00'
                                )
                            .da-form-group
                                label.da-form-label Currency
                                //- currency is fixed to default site value; user cannot change it
                                input.da-form-input(type='text' readonly value=(DEFAULT_CURRENCY || 'EUR'))
                            .da-form-group
                                label.da-form-label(for='quantity') Default quantity
                                input#quantity.da-form-input(
                                    type='number'
                                    name='quantity'
                                    min='0'
                                    value=product && product.quantity != null ? product.quantity : '0'
                                    placeholder='0 = not cartable'
                                )

                //- ── Classification ──────────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Classification
                    .da-card-body
                        .da-form-row
                            .da-form-group
                                label.da-form-label(for='productTypeId') Type
                                select#productTypeId.da-form-select(name='productTypeId')
                                    option(value='') — None —
                                    each pt in productTypes
                                        option(value=pt.id selected=(product && product.productTypeId === pt.id))= pt.name
                            .da-form-group
                                label.da-form-label(for='productCategoryId')
                                    | Category
                                    span.req *
                                select#productCategoryId.da-form-select(name='productCategoryId' required)
                                    option(value='' disabled selected=(!(product && product.productCategoryId))) Select category
                                    each pc in productCategories
                                        option(value=pc.id selected=(product && product.productCategoryId === pc.id))= pc.name
                            .da-form-group
                                label.da-form-label(for='taxRateId')
                                    | Tax Rate
                                    if checkoutVatEnabled
                                        span.req *
                                if checkoutVatEnabled
                                    select#taxRateId.da-form-select(name='taxRateId' required)
                                        option(value='' disabled selected=(!(product && product.taxRateId))) Select tax rate
                                        each tr in taxRates
                                            option(value=tr.id selected=(product && product.taxRateId === tr.id))= tr.name
                                    p.da-form-hint Stripe Tax Rate applied to this product on invoices when checkout VAT is enabled in Settings.
                                else
                                    select#taxRateId.da-form-select(name='taxRateId' disabled=true)
                                        option(value='' selected=(!(product && product.taxRateId))) Not used (VAT off in Settings)
                                        each tr in taxRates
                                            option(value=tr.id selected=(product && product.taxRateId === tr.id))= tr.name
                                    p.da-form-hint Tax assignment is disabled. Enable "Checkout VAT and Stripe invoice tax" under Settings → More settings to require a rate per product.
                            .da-form-group
                                label.da-form-label(for='unitOfMeasure')
                                    | Unit of Measure
                                    span.req *
                                select#unitOfMeasure.da-form-select(name='unitOfMeasure' required)
                                    - var currentUnit = product && product.unitOfMeasure ? product.unitOfMeasure : ''
                                    option(value='' disabled selected=(currentUnit === '')) — Select unit —
                                    option(value='kom' selected=(currentUnit === 'kom')) kom (piece)
                                    option(value='h' selected=(currentUnit === 'h')) h (hour)
                                    option(value='mj' selected=(currentUnit === 'mj')) mj (month)
                                    option(value='god' selected=(currentUnit === 'god')) god (year)
                                    option(value='usl' selected=(currentUnit === 'usl')) usl (service)
                                p.da-form-hint Required for Croatian invoice line items and Stripe e-racuni sync.

                //- ── Variants (extra SKUs; not default, not event-linked) ──
                #productVariantsSection.da-card.da-card--variants(
                    data-currency=(DEFAULT_CURRENCY || 'EUR')
                )
                    .da-card-header
                        h2.da-card-title Variants
                    .da-card-body
                        p.da-form-hint
                            | Extra options customers can buy in addition to the default variant in Pricing above.
                            | Variants used for dated events are managed on the event product pages and do not appear here.
                        .da-variant-add.da-variant-add--panel
                            span.da-form-section-label Add variant
                            .da-form-row.da-variant-add-fields
                                .da-form-group
                                    label.da-form-label(for='newVariantTitle') Title
                                    input#newVariantTitle.da-form-input(
                                        type='text'
                                        autocomplete='off'
                                        placeholder='e.g. Large, VIP'
                                    )
                                .da-form-group
                                    label.da-form-label(for='newVariantPrice') Price
                                    input#newVariantPrice.da-form-input(
                                        type='number'
                                        step='0.01'
                                        min='0'
                                        placeholder='0.00'
                                    )
                                .da-form-group
                                    label.da-form-label(for='newVariantQty') Quantity
                                    input#newVariantQty.da-form-input(
                                        type='number'
                                        min='0'
                                        value='0'
                                    )
                                .da-form-group
                                    label.da-form-label(for='newVariantSku') SKU
                                    input#newVariantSku.da-form-input(
                                        type='text'
                                        autocomplete='off'
                                        placeholder='Auto if empty'
                                    )
                            .da-form-group
                                label.da-checkbox
                                    input#newVariantActive(type='checkbox')
                                    | Active
                                p.da-form-hint(style='margin-top:0.35rem') Leave unchecked to keep the variant off the storefront until you are ready.
                            .da-variant-add-actions
                                button#addProductVariantBtn.da-btn.da-btn--secondary(type='button') Add variant
                        p#productVariantsFeedback.da-variant-feedback(aria-live='polite' role='status')
                        ul#productVariantsList.da-variant-list(data-initial-count=`${(manageableVariants || []).length}`)
                            each v, idx in (manageableVariants || [])
                                li.da-variant-row(data-variant-id=v.id data-variant-index=`${idx}`)
                                    input(type='hidden' name=`variants[${idx}][id]` value=v.id)
                                    input(type='hidden' name=`variants[${idx}][title]` value=v.title)
                                    input(type='hidden' name=`variants[${idx}][priceAmount]` value=v.priceAmount)
                                    input(type='hidden' name=`variants[${idx}][quantity]` value=v.quantity)
                                    input(type='hidden' name=`variants[${idx}][sku]` value=(v.sku || ''))
                                    input(type='hidden' name=`variants[${idx}][active]` value=(v.active ? '1' : '0'))
                                    .da-variant-row-main
                                        span.da-variant-title= v.title
                                        span.da-variant-meta
                                            span.da-variant-price= (DEFAULT_CURRENCY || 'EUR') + ' ' + Number(v.priceAmount).toFixed(2)
                                            span.da-variant-dot  ·
                                            span.da-variant-sku= v.sku
                                            span.da-variant-dot  ·
                                            span.da-variant-qty Qty #{v.quantity}
                                            if !v.active
                                                span.da-variant-badge Inactive
                                    button.da-btn.da-btn--ghost.da-variant-edit(type='button') Edit
                                    button.da-btn.da-btn--ghost.da-variant-remove(
                                        type='button'
                                        data-variant-id=v.id
                                    ) Remove

                //- ── Shipping ────────────────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Shipping
                    .da-card-body
                        .da-form-group
                            label.da-checkbox
                                input#isPhysical(
                                    type='checkbox'
                                    name='isPhysical'
                                    value='on'
                                    checked=product === null || product === undefined || product.isPhysical !== false
                                )
                                | Physical product (requires delivery address at checkout)
                        #physicalProductFields.da-form-row(style='margin-top:1rem')
                            .da-form-group
                                label.da-form-label(for='weight') Weight
                                input#weight.da-form-input(
                                    type='number'
                                    name='weight'
                                    step='0.001'
                                    min='0'
                                    value=product && product.weight != null ? product.weight : ''
                                    placeholder='e.g. 1.5'
                                )
                            .da-form-group
                                label.da-form-label(for='weightUnit') Unit
                                select#weightUnit.da-form-select(name='weightUnit')
                                    option(value='kg' selected=(!product || !product.weightUnit || product.weightUnit === 'kg')) kg
                                    option(value='g' selected=(product && product.weightUnit === 'g')) g

                //- ── Meta & Media ────────────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Meta &amp; Media
                    .da-card-body
                        .da-form-section
                            span.da-form-section-label Meta Objects
                            +metaObjectPickerSection({
                                inputName: 'metaObjectIds[]',
                                attachedMetaObjects: attachedMetaObjects || [],
                                apiUrl: (adminPrefix || '') + '/api/meta-objects',
                                label: null,
                                hint: 'Select meta objects and fill their values below.'
                            })
                        .da-divider
                        .da-form-section(style='margin-bottom:0')
                            span.da-form-section-label Media
                            +mediaPickerSection({
                                inputName: 'mediaIds[]',
                                attachedMedia: attachedMedia || [],
                                uploadsBaseUrl: uploadsBaseUrl || '/uploads',
                                apiUrl: (adminPrefix || '') + '/api/media',
                                featuredMediaId: featuredMediaId || null,
                                featuredInputName: 'featuredMediaId',
                                label: null,
                                hint: 'Select media to attach to this product. Upload new files on the Media page, then select them here.'
                            })

                //- ── Visibility ──────────────────────────────────────
                .da-card
                    .da-card-header
                        h2.da-card-title Visibility
                    .da-card-body
                        .da-form-group
                            label.da-checkbox
                                input(
                                    type='checkbox'
                                    name='active'
                                    value='on'
                                    checked=product === null || product.active
                                )
                                | Active
                            p.da-form-hint(style='margin-top:0.5rem') Make this product visible to customers.

                //- ── Form actions ─────────────────────────────────────
                .da-product-form-actions
                    button.da-btn.da-btn--primary(type='submit')= isEdit ? 'Update Product' : 'Create Product'
                    a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/products') Cancel
                    if isEdit
                        div(style='margin-left:auto')
                            form#delete-product-form(method='post' action=(adminPrefix || '') + '/products/' + product.id + '/delete')
                                button.da-btn.da-btn--danger(
                                    type='button'
                                    data-confirm-modal
                                    data-confirm-title='Delete Product'
                                    data-confirm-msg='Are you sure you want to delete this product? This cannot be undone.'
                                    data-form-id='delete-product-form'
                                ) Delete Product

block append scripts
    script(src='/public/js/admin-product-form.js')
    script(src='/public/js/admin-product-variants.js')
