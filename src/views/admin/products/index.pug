extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader('Products', products ? products.length + ' product' + (products.length !== 1 ? 's' : '') : '0 products')
            +addBtn((adminPrefix || '') + '/products/new', 'Add Product')

        //- ── Products table ───────────────────────────────────────────
        .da-panel
            .da-table-scroll
                table.da-table(role='table' aria-label='Products list')
                    thead
                        tr
                            th(scope='col') Title
                            th(scope='col') Type
                            th(scope='col') Category
                            th.da-col-price(scope='col') Price
                            th(scope='col') Status
                            th(scope='col' style='text-align:right') Actions
                    tbody
                        if products && products.length
                            each p in products
                                tr.da-row(data-product-id=p.id)
                                    td
                                        span.da-cell-primary= p.title
                                    td
                                        span.da-cell-secondary= p.ProductType ? p.ProductType.name : '—'
                                    td
                                        span.da-cell-secondary= p.ProductCategory ? p.ProductCategory.name : '—'
                                    td.da-col-price
                                        span.da-cell-secondary= p.price != null ? Number(p.price).toFixed(2) + ' ' + (p.currency || 'USD') : '—'
                                    td
                                        if p.active
                                            span.da-badge.da-badge--success Active
                                        else
                                            span.da-badge.da-badge--neutral Inactive
                                    td
                                        .da-cell-actions
                                            a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/products/' + p.id + '/edit' aria-label='Edit ' + p.title) Edit
                        else
                            +tableEmpty('No products yet.', 6)
