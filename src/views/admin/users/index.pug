extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        .da-page-header
            .da-page-header-left
                h1.da-page-title Users
                p.da-page-subtitle
                    | #{(admins ? admins.length : 0) + (users ? users.length : 0)} total members

            .da-page-header-right
                a.da-btn.da-btn--primary(href=(adminPrefix || '') + '/users/new')
                    svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        line(x1='12' y1='5' x2='12' y2='19')
                        line(x1='5' y1='12' x2='19' y2='12')
                    | Add User

        //- ── Admins section ──────────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title Admins
                span.da-count= admins ? admins.length : 0

            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Admin users')
                        thead
                            tr
                                th(scope='col') Email
                                th.da-col-username(scope='col') Username
                                th.da-col-created(scope='col') Created
                                th(scope='col' style='text-align:right') Actions
                        tbody
                            if admins && admins.length
                                each u in admins
                                    tr.da-row(data-user-id=u.id)
                                        td
                                            span.da-cell-primary= u.email
                                        td.da-col-username
                                            span.da-cell-secondary= u.username || '—'
                                        td.da-col-created
                                            span.da-cell-muted= u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) : '—'
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/users/' + u.id + '/edit' aria-label='Edit ' + u.email) Edit
                            else
                                tr
                                    td(colspan='4')
                                        .da-table-empty No admins yet.

        //- ── Regular users section ───────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title Users
                span.da-count= users ? users.length : 0

            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Regular users')
                        thead
                            tr
                                th(scope='col') Email
                                th.da-col-username(scope='col') Username
                                th.da-col-created(scope='col') Created
                                th(scope='col' style='text-align:right') Actions
                        tbody
                            if users && users.length
                                each u in users
                                    tr.da-row(data-user-id=u.id)
                                        td
                                            span.da-cell-primary= u.email
                                        td.da-col-username
                                            span.da-cell-secondary= u.username || '—'
                                        td.da-col-created
                                            span.da-cell-muted= u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) : '—'
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/users/' + u.id + '/edit' aria-label='Edit ' + u.email) Edit
                            else
                                tr
                                    td(colspan='4')
                                        .da-table-empty No users yet.

