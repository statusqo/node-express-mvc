extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader('Users', ((admins ? admins.length : 0) + (users ? users.length : 0)) + ' total members')
            +addBtn((adminPrefix || '') + '/users/new', 'Add User')

        //- ── Admins section ──────────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title Admins
                span.da-count= admins ? admins.length : 0

            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Admin users')
                        thead
                            tr
                                th(scope='col') User #
                                th(scope='col') Email
                                th.da-col-username(scope='col') Username
                                th(scope='col') Forename
                                th(scope='col') Surname
                                th.da-col-created(scope='col') Created
                                th(scope='col' style='text-align:right') Actions
                        tbody
                            if admins && admins.length
                                each u in admins
                                    tr.da-row(data-user-id=u.id)
                                        td
                                            span.da-cell-primary= u.userNumber || '—'
                                        td
                                            span.da-cell-primary= u.email
                                        td.da-col-username
                                            span.da-cell-secondary= u.username || '—'
                                        td
                                            span.da-cell-secondary= u.forename || '—'
                                        td
                                            span.da-cell-secondary= u.surname || '—'
                                        td.da-col-created
                                            span.da-cell-muted= u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/users/' + u.id + '/edit' aria-label='Edit ' + u.email) Edit
                            else
                                +tableEmpty('No admins yet.', 7)

        //- ── Regular users section ───────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title Users
                span.da-count= users ? users.length : 0

            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Regular users')
                        thead
                            tr
                                th(scope='col') User #
                                th(scope='col') Email
                                th.da-col-username(scope='col') Username
                                th(scope='col') Forename
                                th(scope='col') Surname
                                th.da-col-created(scope='col') Created
                                th(scope='col' style='text-align:right') Actions
                        tbody
                            if users && users.length
                                each u in users
                                    tr.da-row(data-user-id=u.id)
                                        td
                                            span.da-cell-primary= u.userNumber || '—'
                                        td
                                            span.da-cell-primary= u.email
                                        td.da-col-username
                                            span.da-cell-secondary= u.username || '—'
                                        td
                                            span.da-cell-secondary= u.forename || '—'
                                        td
                                            span.da-cell-secondary= u.surname || '—'
                                        td.da-col-created
                                            span.da-cell-muted= u.createdAt ? new Date(u.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/users/' + u.id + '/edit' aria-label='Edit ' + u.email) Edit
                            else
                                +tableEmpty('No users yet.', 7)

