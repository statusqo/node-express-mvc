extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader(isEdit ? 'Edit User' : 'Add User', isEdit ? (user && user.email ? user.email : 'Update user details') : 'Create a new account')
            +backBtn((adminPrefix || '') + '/users', 'Back to Users')

        +formError(error)

        //- ── Form grid: main column + aside (edit only) ──────────────
        .da-form-grid(class=isEdit ? '' : 'da-form-grid--narrow')

            //- ── Main column ─────────────────────────────────────────
            .da-form-main

                //- Account details card
                .da-card
                    .da-card-header
                        h2.da-card-title Account Details
                    .da-card-body
                        form#userEditForm(
                            method='post'
                            action=isEdit ? (adminPrefix || '') + '/users/' + user.id + '/edit' : (adminPrefix || '') + '/users/new'
                        )
                            .da-form-section
                                span.da-form-section-label Identity

                                .da-form-group
                                    label.da-form-label(for='username') Username
                                    input#username.da-form-input(
                                        type='text'
                                        name='username'
                                        value=user ? user.username : ''
                                        placeholder='3–30 characters, optional'
                                        autocomplete='username'
                                    )
                                    p.da-form-hint Shown publicly where applicable.

                                .da-form-group
                                    label.da-form-label(for='email')
                                        | Email
                                        span.req *
                                    input#email.da-form-input(
                                        type='email'
                                        name='email'
                                        required
                                        value=user ? user.email : ''
                                        placeholder='user@example.com'
                                        autocomplete='email'
                                    )

                                if !isEdit
                                    .da-form-group
                                        label.da-form-label(for='password')
                                            | Password
                                            span.req *
                                        input#password.da-form-input(
                                            type='password'
                                            name='password'
                                            required
                                            placeholder='Minimum 4 characters'
                                            autocomplete='new-password'
                                        )

                            .da-form-section
                                span.da-form-section-label Person Type

                                .da-form-group
                                    label.da-form-label(for='personType') Person Type
                                    select#personType.da-form-select(name='personType')
                                        option(value='private' selected=(!user || user.personType !== 'legal')) Private person
                                        option(value='legal' selected=(user && user.personType === 'legal')) Legal person (company)

                                .da-form-row
                                    .da-form-group
                                        label.da-form-label(for='forename') Forename
                                        input#forename.da-form-input(
                                            type='text'
                                            name='forename'
                                            value=user ? (user.forename || '') : ''
                                            placeholder='First name'
                                            autocomplete='given-name'
                                        )
                                    .da-form-group
                                        label.da-form-label(for='surname') Surname
                                        input#surname.da-form-input(
                                            type='text'
                                            name='surname'
                                            value=user ? (user.surname || '') : ''
                                            placeholder='Last name'
                                            autocomplete='family-name'
                                        )
                                .da-form-group
                                    label.da-form-label(for='mobile') Mobile
                                    input#mobile.da-form-input(
                                        type='tel'
                                        name='mobile'
                                        value=user ? (user.mobile || '') : ''
                                        placeholder='+385 91 234 5678'
                                        autocomplete='tel'
                                    )

                                .da-form-group
                                    label.da-form-label(for='companyName') Company Name
                                    input#companyName.da-form-input(
                                        type='text'
                                        name='companyName'
                                        value=user ? (user.companyName || '') : ''
                                        placeholder='Company / organisation name'
                                    )
                                .da-form-group
                                    label.da-form-label(for='companyOib') OIB (Tax ID)
                                    input#companyOib.da-form-input(
                                        type='text'
                                        name='companyOib'
                                        value=user ? (user.companyOib || '') : ''
                                        maxlength='11'
                                        pattern='\\d{11}'
                                        placeholder='11-digit Croatian tax ID'
                                    )

                            .da-form-section
                                span.da-form-section-label Permissions

                                .da-form-group
                                    label.da-checkbox
                                        input(type='checkbox' name='isAdmin' value='on' checked=user && user.isAdmin)
                                        | Admin access
                                    p.da-form-hint(style='margin-top:0.5rem') Grants full access to the admin panel.

                            if isEdit
                                input#hiddenPassword(type='hidden' name='password' value='')

                    .da-card-footer
                        button.da-btn.da-btn--primary(type='submit' form='userEditForm')= isEdit ? 'Save Changes' : 'Create User'
                        a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/users') Cancel

                //- Danger zone (edit only)
                if isEdit
                    form#delete-user-form(method='post' action=(adminPrefix || '') + '/users/' + user.id + '/delete')
                        button.da-btn.da-btn--danger(
                            type='button'
                            data-confirm-modal
                            data-confirm-title='Delete User'
                            data-confirm-msg='This cannot be undone. The following will be removed:'
                            data-confirm-bullets='["User account and login","All saved addresses","All saved payment methods"]'
                            data-form-id='delete-user-form'
                        ) Delete User

            //- ── Aside column (edit only) ────────────────────────────
            if isEdit
                .da-form-aside

                    //- Addresses
                    .da-card
                        .da-card-header
                            h2.da-card-title Addresses
                        .da-card-body
                            if addresses && addresses.length
                                .da-detail-list
                                    each addr in addresses
                                        .da-detail-item
                                            p.da-detail-label
                                                | #{addr.label ? addr.label.charAt(0).toUpperCase() + addr.label.slice(1) : 'Address'}
                                            p.da-detail-line= addr.line1
                                            if addr.line2
                                                p.da-detail-line= addr.line2
                                            p.da-detail-line= [addr.city, addr.state, addr.postcode].filter(Boolean).join(', ')
                                            p.da-detail-line= addr.country
                            else
                                p.da-aside-empty No saved addresses.

                    //- Payment methods
                    .da-card
                        .da-card-header
                            h2.da-card-title Payment Methods
                        .da-card-body
                            if paymentMethods && paymentMethods.length
                                .da-detail-list
                                    each pm in paymentMethods
                                        .da-detail-item
                                            p.da-detail-label
                                                | #{(pm.brand || 'Card').charAt(0).toUpperCase() + (pm.brand || 'card').slice(1)} ****#{pm.last4 || '????'}
                                                if pm.isDefault
                                                    span.da-badge.da-badge--info(style='margin-left:0.5rem') Default
                                            if pm.expiryMonth && pm.expiryYear
                                                p.da-detail-line Expires #{pm.expiryMonth}/#{pm.expiryYear}
                            else
                                p.da-aside-empty No saved payment methods.

                    //- Password reset
                    .da-card
                        .da-card-header
                            h2.da-card-title Password
                        .da-card-body
                            .da-reset-trigger-row
                                p.da-reset-desc
                                    | Securely update this user's password.
                                button#showResetBtn.da-btn.da-btn--secondary(type='button') Reset Password

                            .da-reset-fields#resetFields
                                .da-reset-fields-inner
                                    .da-form-group
                                        label.da-form-label(for='newPassword') New password
                                        input#newPassword.da-form-input(
                                            type='password'
                                            placeholder='Minimum 4 characters'
                                            autocomplete='new-password'
                                        )
                                    .da-form-group
                                        label.da-form-label(for='confirmPassword') Confirm new password
                                        input#confirmPassword.da-form-input(
                                            type='password'
                                            placeholder='Repeat new password'
                                            autocomplete='new-password'
                                        )
                                    p#resetError.da-reset-error

                                    .da-reset-actions
                                        button#setPasswordBtn.da-btn.da-btn--primary(type='button') Set Password &amp; Save
                                        button#cancelResetBtn.da-btn.da-btn--secondary(type='button') Cancel

        //- ── Orders table (edit only) ────────────────────────────────
        if isEdit
            .da-section(style='margin-top:2rem')
                .da-section-header
                    h2.da-section-title Order History
                    if orders && orders.length
                        span.da-count= orders.length + ' order' + (orders.length !== 1 ? 's' : '')

                .da-panel
                    .da-table-scroll
                        table.da-table(role='table' aria-label='User order history')
                            thead
                                tr
                                    th(scope='col') Order ID
                                    th(scope='col') Payment
                                    th(scope='col') Fulfillment
                                    th.da-col-created(scope='col') Total
                                    th.da-col-created(scope='col') Date
                            tbody
                                if orders && orders.length
                                    each order in orders
                                        - var payClass = ({paid:'success',pending:'warning',failed:'danger',refunded:'info',cancelled:'neutral'})[order.paymentStatus] || 'neutral'
                                        - var fulClass = ({pending:'warning',processing:'info',shipped:'info',delivered:'success',refund_requested:'danger',refunded:'neutral',cancelled:'danger',returned:'neutral'})[order.fulfillmentStatus] || 'neutral'
                                        tr
                                            td
                                                span.da-cell-mono= order.id ? order.id.slice(0, 8) + '…' : '—'
                                            td
                                                if order.paymentStatus
                                                    span.da-badge(class='da-badge--' + payClass)= order.paymentStatus.charAt(0).toUpperCase() + order.paymentStatus.slice(1)
                                                else
                                                    span.da-cell-muted —
                                            td
                                                if order.fulfillmentStatus
                                                    span.da-badge(class='da-badge--' + fulClass)= order.fulfillmentStatus.charAt(0).toUpperCase() + order.fulfillmentStatus.slice(1).replace(/_/g, ' ')
                                                else
                                                    span.da-cell-muted —
                                            td.da-col-created
                                                span.da-cell-secondary= order.total != null ? Number(order.total).toFixed(2) + ' ' + (order.currency || 'USD') : '—'
                                            td.da-col-created
                                                span.da-cell-muted= order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'
                                else
                                    tr
                                        td(colspan='5')
                                            .da-table-empty No orders yet.

block append scripts
    script(src='/public/js/admin-user-form.js')
