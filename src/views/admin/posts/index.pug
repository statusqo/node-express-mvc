extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader('Posts', (posts ? posts.length : 0) + ' post' + ((posts && posts.length !== 1) ? 's' : ''))
            +addBtn((adminPrefix || '') + '/blog/new', 'Add Post')

        //- ── Posts table ─────────────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title All posts
                span.da-count= posts ? posts.length : 0

            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Blog posts list')
                        thead
                            tr
                                th(scope='col') Title
                                th(scope='col') Slug
                                th(scope='col') Status
                                th(scope='col') Published
                                th(scope='col' style='text-align:right') Actions
                        tbody
                            if posts && posts.length
                                each p in posts
                                    tr.da-row(data-post-id=p.id)
                                        td
                                            span.da-cell-primary= p.title
                                        td
                                            span.da-cell-mono= p.slug || '—'
                                        td
                                            if p.published
                                                span.da-badge.da-badge--success Published
                                            else
                                                span.da-badge.da-badge--neutral Draft
                                        td
                                            span.da-cell-muted= p.publishedAt ? new Date(p.publishedAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/blog/' + p.id + '/edit' aria-label='Edit ' + p.title) Edit
                            else
                                +tableEmpty('No posts yet.', 5)
