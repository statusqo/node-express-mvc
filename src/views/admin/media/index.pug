extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        if flash && flash.message
            p.admin-flash(class='admin-flash-' + (flash.type || 'info'))= flash.message

        //- ── Page header ─────────────────────────────────────────────
        .da-page-header
            .da-page-header-left
                h1.da-page-title Media Library
                p.da-page-subtitle= (media ? media.length : 0) + ' file' + ((media && media.length !== 1) ? 's' : '')

        //- ── Upload ──────────────────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title Upload
            .da-card
                .da-card-header
                    h2.da-card-title Upload a file
                    p(style='margin:0; font-size: 13px; color: var(--ds-text-3);') Add images, PDFs and other media for products and collections.
                .da-card-body
                    form(method='post' action=(adminPrefix || '') + '/media/upload' enctype='multipart/form-data')
                        label.admin-upload-zone(for='media-file')
                            svg.admin-upload-zone-icon(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' aria-hidden='true')
                                path(stroke-linecap='round' stroke-linejoin='round' d='M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5')
                            p.admin-upload-zone-label Click to select a file
                            p.admin-upload-zone-hint JPG, PNG, GIF, WebP, SVG · PDF
                            p#upload-selected.admin-upload-zone-selected
                        input#media-file.admin-upload-file-input(
                            type='file'
                            name='file'
                            accept='.jpg,.jpeg,.png,.gif,.webp,.svg,.pdf,image/*,application/pdf'
                        )
                        .da-form-group(style='margin-top: 1rem;')
                            label.da-form-label(for='alt') Alt text (optional)
                            input#alt.da-form-input(type='text' name='alt' placeholder='Describe the image for screen readers')
                        button.da-btn.da-btn--primary(type='submit') Upload file

        //- ── Media table ─────────────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title All media
                span.da-count= media ? media.length : 0
            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Media library')
                        thead
                            tr
                                th(scope='col') Preview
                                th(scope='col') Filename
                                th(scope='col') Type
                                th(scope='col') Size
                                th(scope='col') Alt
                                th(scope='col' style='text-align:right') Actions
                        tbody
                            if media && media.length
                                each m in media
                                    tr.da-row(data-media-id=m.id)
                                        td
                                            if m.mimeType && m.mimeType.startsWith('image/')
                                                a(href=m.urlPath target='_blank' rel='noopener noreferrer')
                                                    img.admin-media-preview(src=m.urlPath alt=m.alt || m.filename || 'Media')
                                            else
                                                .admin-media-preview-placeholder File
                                        td
                                            span.da-cell-primary= m.filename || m.path
                                        td
                                            span.da-cell-muted= m.mimeType || '—'
                                        td
                                            span.da-cell-secondary= m.size != null ? (m.size < 1024 ? m.size + ' B' : (m.size < 1048576 ? (m.size / 1024).toFixed(1) + ' KB' : (m.size / 1048576).toFixed(1) + ' MB')) : '—'
                                        td
                                            span.da-cell-muted= m.alt || '—'
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=m.urlPath target='_blank' rel='noopener noreferrer' aria-label='View ' + (m.filename || 'file')) View
                                                .da-delete-wrap(aria-label='Delete media actions')
                                                    button.da-row-btn.da-row-btn--delete.da-delete-trigger(
                                                        type='button'
                                                        aria-label='Delete ' + (m.filename || m.path)
                                                        aria-expanded='false'
                                                    ) Delete
                                                    .da-confirm-group(role='group' aria-label='Confirm deletion')
                                                        button.da-row-btn.da-row-btn--cancel.da-delete-cancel(
                                                            type='button'
                                                            aria-label='Cancel deletion'
                                                        ) No
                                                        span.da-confirm-sep(aria-hidden='true')
                                                        form.da-form-inline.da-delete-form(
                                                            method='post'
                                                            action=(adminPrefix || '') + '/media/' + m.id + '/delete'
                                                        )
                                                            button.da-row-btn.da-row-btn--confirm(
                                                                type='submit'
                                                                aria-label='Confirm delete ' + (m.filename || 'file')
                                                            ) Yes, delete
                            else
                                tr
                                    td(colspan='6')
                                        .da-table-empty No media yet. Upload a file above.

block append scripts
    script.
        (function () {
            'use strict';
            var sel = document.getElementById('upload-selected');
            var inp = document.getElementById('media-file');
            if (inp && sel) {
                inp.addEventListener('change', function () {
                    sel.textContent = this.files[0] ? this.files[0].name : '';
                });
            }

            /* ── Delete confirmation flow (same as Users page) ───────── */
            function initDeleteFlow() {
                document.querySelectorAll('.da-delete-trigger').forEach(function (trigger) {
                    trigger.addEventListener('click', function () {
                        var row = trigger.closest('tr.da-row');
                        if (!row) return;
                        row.classList.add('da-row--confirming');
                        trigger.setAttribute('aria-expanded', 'true');
                        var cancel = row.querySelector('.da-delete-cancel');
                        if (cancel) setTimeout(function () { cancel.focus(); }, 200);
                    });
                });

                document.querySelectorAll('.da-delete-cancel').forEach(function (cancel) {
                    cancel.addEventListener('click', function () {
                        var row = cancel.closest('tr.da-row');
                        if (!row) return;
                        row.classList.remove('da-row--confirming');
                        var trigger = row.querySelector('.da-delete-trigger');
                        if (trigger) {
                            trigger.setAttribute('aria-expanded', 'false');
                            setTimeout(function () { trigger.focus(); }, 200);
                        }
                    });
                });

                document.querySelectorAll('.da-delete-form').forEach(function (form) {
                    form.addEventListener('submit', function (e) {
                        e.preventDefault();
                        var row = form.closest('tr');
                        if (!row) { form.submit(); return; }
                        row.classList.add('da-row--removing');
                        setTimeout(function () { form.submit(); }, 340);
                    });
                });
            }

            document.addEventListener('keydown', function (e) {
                if (e.key !== 'Escape') return;
                document.querySelectorAll('tr.da-row--confirming').forEach(function (row) {
                    row.classList.remove('da-row--confirming');
                    var trigger = row.querySelector('.da-delete-trigger');
                    if (trigger) trigger.setAttribute('aria-expanded', 'false');
                });
            });

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initDeleteFlow);
            } else {
                initDeleteFlow();
            }
        })();
