extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader('Collections', (collections ? collections.length : 0) + ' collection' + ((collections && collections.length !== 1) ? 's' : ''))
            +addBtn((adminPrefix || '') + '/collections/new', 'Add Collection')

        //- ── Collections table ───────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title All collections
                span.da-count= collections ? collections.length : 0

            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Collections list')
                        thead
                            tr
                                th(scope='col') Title
                                th(scope='col') Slug
                                th(scope='col') Status
                                th(scope='col' style='text-align:right') Actions
                        tbody
                            if collections && collections.length
                                each c in collections
                                    tr.da-row(data-collection-id=c.id)
                                        td
                                            span.da-cell-primary= c.title
                                        td
                                            span.da-cell-mono= c.slug || '—'
                                        td
                                            if c.active
                                                span.da-badge.da-badge--success Active
                                            else
                                                span.da-badge.da-badge--neutral Inactive
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/collections/' + c.id + '/edit' aria-label='Edit ' + c.title) Edit
                            else
                                +tableEmpty('No collections yet.', 4)
