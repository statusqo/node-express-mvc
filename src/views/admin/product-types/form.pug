extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader(isEdit ? 'Edit Product Type' : 'New Product Type', isEdit && productType && productType.name ? productType.name : 'Define a classification for your products')
            +backBtn((adminPrefix || '') + '/product-types', 'Back to Product Types')

        +formError(error)

        //- ── Form (narrow single-card layout) ─────────────────────────
        .da-pt-form-wrap
            .da-card
                .da-card-header
                    h2.da-card-title Details
                .da-card-body
                    form#ptForm(
                        method='post'
                        action=isEdit ? (adminPrefix || '') + '/product-types/' + productType.id + '/edit' : (adminPrefix || '') + '/product-types/new'
                    )
                        .da-form-group
                            label.da-form-label(for='name')
                                | Name
                                span.req *
                            input#name.da-form-input(
                                type='text'
                                name='name'
                                required
                                value=productType ? productType.name : ''
                                placeholder='e.g. Webinar'
                                autofocus
                            )
                        .da-form-group
                            label.da-form-label(for='slug') Slug
                            input#slug.da-form-input(
                                type='text'
                                name='slug'
                                value=productType ? productType.slug : ''
                                placeholder='Auto-generated from name if left blank'
                            )
                            p.da-form-hint Used in URLs and API identifiers. Lowercase letters, numbers, and hyphens only.

                .da-card-footer
                    button.da-btn.da-btn--primary(type='submit' form='ptForm')= isEdit ? 'Save Changes' : 'Create Product Type'
                    a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/product-types') Cancel
                    if isEdit
                        div(style='margin-left:auto')
                            form#delete-product-type-form(method='post' action=(adminPrefix || '') + '/product-types/' + productType.id + '/delete')
                                button.da-btn.da-btn--danger(
                                    type='button'
                                    data-confirm-modal
                                    data-confirm-title='Delete Product Type'
                                    data-confirm-msg='Are you sure you want to delete this product type? This cannot be undone.'
                                    data-form-id='delete-product-type-form'
                                ) Delete Product Type
