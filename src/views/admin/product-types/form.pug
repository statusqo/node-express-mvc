extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        .da-page-header
            .da-page-header-left
                h1.da-page-title= isEdit ? 'Edit Product Type' : 'New Product Type'
                p.da-page-subtitle= isEdit && productType && productType.name ? productType.name : 'Define a classification for your products'
            .da-page-header-right
                a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/product-types')
                    svg(xmlns='http://www.w3.org/2000/svg' width='13' height='13' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        polyline(points='15 18 9 12 15 6')
                    | Back to Product Types

        if error
            p.admin-flash.admin-flash-error= error

        //- ── Form (narrow single-card layout) ─────────────────────────
        .da-pt-form-wrap
            .da-card
                .da-card-header
                    h2.da-card-title Details
                .da-card-body
                    form#ptForm(
                        method='post'
                        action=isEdit ? (adminPrefix || '') + '/product-types/' + productType.id + '/edit' : (adminPrefix || '') + '/product-types/new'
                    )
                        .da-form-group
                            label.da-form-label(for='name')
                                | Name
                                span.req *
                            input#name.da-form-input(
                                type='text'
                                name='name'
                                required
                                value=productType ? productType.name : ''
                                placeholder='e.g. Webinar'
                                autofocus
                            )
                        .da-form-group
                            label.da-form-label(for='slug') Slug
                            input#slug.da-form-input(
                                type='text'
                                name='slug'
                                value=productType ? productType.slug : ''
                                placeholder='Auto-generated from name if left blank'
                            )
                            p.da-form-hint Used in URLs and API identifiers. Lowercase letters, numbers, and hyphens only.

                .da-card-footer
                    button.da-btn.da-btn--primary(type='submit' form='ptForm')= isEdit ? 'Save Changes' : 'Create Product Type'
                    a.da-btn.da-btn--secondary(href=(adminPrefix || '') + '/product-types') Cancel
