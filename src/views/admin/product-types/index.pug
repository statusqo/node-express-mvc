extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        .da-page-header
            .da-page-header-left
                h1.da-page-title Product Types
                p.da-page-subtitle= productTypes ? productTypes.length + ' type' + (productTypes.length !== 1 ? 's' : '') : '0 types'
            .da-page-header-right
                a.da-btn.da-btn--primary(href=(adminPrefix || '') + '/product-types/new')
                    svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        line(x1='12' y1='5' x2='12' y2='19')
                        line(x1='5' y1='12' x2='19' y2='12')
                    | Add Product Type

        //- ── Product types table ──────────────────────────────────────
        .da-panel
            .da-table-scroll
                table.da-table(role='table' aria-label='Product types list')
                    thead
                        tr
                            th(scope='col') Name
                            th.da-col-slug(scope='col') Slug
                            th(scope='col' style='text-align:right') Actions
                    tbody
                        if productTypes && productTypes.length
                            each pt in productTypes
                                tr.da-row(data-pt-id=pt.id)
                                    td
                                        span.da-cell-primary= pt.name
                                    td.da-col-slug
                                        span.da-cell-mono= pt.slug || '—'
                                    td
                                        .da-cell-actions
                                            a.da-row-btn.da-row-btn--edit(
                                                href=(adminPrefix || '') + '/product-types/' + pt.id + '/edit'
                                                aria-label='Edit ' + pt.name
                                            ) Edit
                                            .da-delete-wrap(aria-label='Delete product type actions')
                                                button.da-row-btn.da-row-btn--delete.da-delete-trigger(
                                                    type='button'
                                                    aria-label='Delete ' + pt.name
                                                    aria-expanded='false'
                                                    title='Products using this type will have their type cleared'
                                                ) Delete
                                                .da-confirm-group(role='group' aria-label='Confirm deletion')
                                                    button.da-row-btn.da-row-btn--cancel.da-delete-cancel(
                                                        type='button'
                                                        aria-label='Cancel deletion'
                                                    ) No
                                                    span.da-confirm-sep(aria-hidden='true')
                                                    form.da-form-inline.da-delete-form(
                                                        method='post'
                                                        action=(adminPrefix || '') + '/product-types/' + pt.id + '/delete'
                                                    )
                                                        button.da-row-btn.da-row-btn--confirm(
                                                            type='submit'
                                                            aria-label='Confirm delete ' + pt.name
                                                        ) Yes, delete
                        else
                            tr
                                td(colspan='3')
                                    .da-table-empty
                                        svg(xmlns='http://www.w3.org/2000/svg' width='20' height='20' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true' style='color:var(--ds-text-3)')
                                            rect(x='2' y='7' width='20' height='14' rx='2' ry='2')
                                            path(d='M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16')
                                        span No product types yet.

block append scripts
    script.
        (function () {
            'use strict';

            function initDeleteFlow() {
                document.querySelectorAll('.da-delete-trigger').forEach(function (trigger) {
                    trigger.addEventListener('click', function () {
                        var row = trigger.closest('tr.da-row');
                        if (!row) return;
                        row.classList.add('da-row--confirming');
                        trigger.setAttribute('aria-expanded', 'true');
                        var cancel = row.querySelector('.da-delete-cancel');
                        if (cancel) setTimeout(function () { cancel.focus(); }, 200);
                    });
                });

                document.querySelectorAll('.da-delete-cancel').forEach(function (cancel) {
                    cancel.addEventListener('click', function () {
                        var row = cancel.closest('tr.da-row');
                        if (!row) return;
                        row.classList.remove('da-row--confirming');
                        var trigger = row.querySelector('.da-delete-trigger');
                        if (trigger) {
                            trigger.setAttribute('aria-expanded', 'false');
                            setTimeout(function () { trigger.focus(); }, 200);
                        }
                    });
                });

                document.querySelectorAll('.da-delete-form').forEach(function (form) {
                    form.addEventListener('submit', function (e) {
                        e.preventDefault();
                        var row = form.closest('tr');
                        if (!row) { form.submit(); return; }
                        row.classList.add('da-row--removing');
                        setTimeout(function () { form.submit(); }, 340);
                    });
                });
            }

            document.addEventListener('keydown', function (e) {
                if (e.key !== 'Escape') return;
                document.querySelectorAll('tr.da-row--confirming').forEach(function (row) {
                    row.classList.remove('da-row--confirming');
                    var trigger = row.querySelector('.da-delete-trigger');
                    if (trigger) trigger.setAttribute('aria-expanded', 'false');
                });
            });

            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', initDeleteFlow);
            } else {
                initDeleteFlow();
            }
        })();
