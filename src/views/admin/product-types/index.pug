extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader('Product Types', productTypes ? productTypes.length + ' type' + (productTypes.length !== 1 ? 's' : '') : '0 types')
            +addBtn((adminPrefix || '') + '/product-types/new', 'Add Product Type')

        //- ── Product types table ──────────────────────────────────────
        .da-panel
            .da-table-scroll
                table.da-table(role='table' aria-label='Product types list')
                    thead
                        tr
                            th(scope='col') Name
                            th.da-col-slug(scope='col') Slug
                            th(scope='col' style='text-align:right') Actions
                    tbody
                        if productTypes && productTypes.length
                            each pt in productTypes
                                tr.da-row(data-pt-id=pt.id)
                                    td
                                        span.da-cell-primary= pt.name
                                    td.da-col-slug
                                        span.da-cell-mono= pt.slug || '—'
                                    td
                                        .da-cell-actions
                                            a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/product-types/' + pt.id + '/edit' aria-label='Edit ' + pt.name) Edit
                        else
                            +tableEmpty('No product types yet.', 3)
