extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        +pageHeader('Menus', (menusList ? menusList.length : 0) + ' menu' + ((menusList && menusList.length !== 1) ? 's' : ''))
            +addBtn((adminPrefix || '') + '/menus/new', 'Add Menu')

        //- ── Menus table ─────────────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title All menus
                span.da-count= menusList ? menusList.length : 0

            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Menus list')
                        thead
                            tr
                                th(scope='col') Name
                                th(scope='col') Slug
                                th(scope='col') Items
                                th(scope='col') Status
                                th.da-col-actions(scope='col') Actions
                        tbody
                            if menusList && menusList.length
                                each m in menusList
                                    tr.da-row(data-menu-id=m.id)
                                        td
                                            span.da-cell-primary= m.name
                                        td
                                            span.da-cell-mono= m.slug || '—'
                                        td
                                            span.da-badge.da-badge--neutral= m.itemCount || 0
                                        td
                                            if m.active
                                                span.da-badge.da-badge--success Active
                                            else
                                                span.da-badge.da-badge--neutral Inactive
                                        td.da-col-actions
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/menu-items?menu=' + m.slug aria-label='Items for ' + m.name) Items
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/menus/' + m.id + '/edit' aria-label='Edit ' + m.name) Edit
                            else
                                +tableEmpty('No menus yet.', 5)
