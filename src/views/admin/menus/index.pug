extends ../../layouts/admin

block append links
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)

block content
    .da-page

        //- ── Page header ─────────────────────────────────────────────
        .da-page-header
            .da-page-header-left
                h1.da-page-title Menus
                p.da-page-subtitle= (menusList ? menusList.length : 0) + ' menu' + ((menusList && menusList.length !== 1) ? 's' : '')

            .da-page-header-right
                a.da-btn.da-btn--primary(href=(adminPrefix || '') + '/menus/new')
                    svg(xmlns='http://www.w3.org/2000/svg' width='14' height='14' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true')
                        line(x1='12' y1='5' x2='12' y2='19')
                        line(x1='5' y1='12' x2='19' y2='12')
                    | Add Menu

        //- ── Menus table ─────────────────────────────────────────────
        .da-section
            .da-section-header
                h2.da-section-title All menus
                span.da-count= menusList ? menusList.length : 0

            .da-panel
                .da-table-scroll
                    table.da-table(role='table' aria-label='Menus list')
                        thead
                            tr
                                th(scope='col') Name
                                th(scope='col') Slug
                                th(scope='col') Items
                                th(scope='col') Status
                                th.da-col-actions(scope='col') Actions
                        tbody
                            if menusList && menusList.length
                                each m in menusList
                                    tr.da-row(data-menu-id=m.id)
                                        td
                                            span.da-cell-primary= m.name
                                        td
                                            span.da-cell-mono= m.slug || '—'
                                        td
                                            span.da-badge.da-badge--neutral= m.itemCount || 0
                                        td
                                            if m.active
                                                span.da-badge.da-badge--success Active
                                            else
                                                span.da-badge.da-badge--neutral Inactive
                                        td.da-col-actions
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/menu-items?menu=' + m.slug aria-label='Items for ' + m.name) Items
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/menus/' + m.id + '/edit' aria-label='Edit ' + m.name) Edit
                                                .da-delete-wrap(aria-label='Delete menu actions')
                                                    button.da-row-btn.da-row-btn--delete.da-delete-trigger(
                                                        type='button'
                                                        aria-label='Delete ' + m.name
                                                        aria-expanded='false'
                                                    ) Delete
                                                    .da-confirm-group(role='group' aria-label='Confirm deletion')
                                                        button.da-row-btn.da-row-btn--cancel.da-delete-cancel(
                                                            type='button'
                                                            aria-label='Cancel deletion'
                                                        ) No
                                                        span.da-confirm-sep(aria-hidden='true')
                                                        form.da-form-inline.da-delete-form(
                                                            method='post'
                                                            action=(adminPrefix || '') + '/menus/' + m.id + '/delete'
                                                        )
                                                            button.da-row-btn.da-row-btn--confirm(
                                                                type='submit'
                                                                aria-label='Confirm delete ' + m.name
                                                            ) Yes, delete
                            else
                                tr
                                    td(colspan='5')
                                        .da-table-empty No menus yet.
