extends ../../layouts/admin

block content
    .da-page

        +pageHeader('Product Categories', 'Manage categories and their KPD classification codes')
            +addBtn((adminPrefix || '') + '/product-categories/new', 'New Category')

        .da-section
            .da-panel
                if productCategories && productCategories.length
                    .da-table-scroll
                        table.da-table
                            thead
                                tr
                                    th Name
                                    th Slug
                                    th KPD Code
                                    th(style='text-align:right') Actions
                            tbody
                                each cat in productCategories
                                    tr.da-row(data-id=cat.id)
                                        td.da-cell-primary= cat.name
                                        td= cat.slug
                                        td
                                            if cat.kpdCode
                                                span.da-badge.da-badge--info= cat.kpdCode
                                            else
                                                span.da-badge.da-badge--neutral —
                                        td
                                            .da-cell-actions
                                                a.da-row-btn.da-row-btn--edit(href=(adminPrefix || '') + '/product-categories/' + cat.id + '/edit') Edit
                else
                    p.da-table-empty No product categories yet.
