extends ../../layouts/main

block append links
  link(rel="stylesheet" href="/public/css/rate-limit.css")

block content
  style.
    /* Critical inline styles – ensure visibility even if external CSS fails */
    .rate-limit-section {
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 60vh;
      padding: 3rem 1.5rem;
      background: #f5f5f5 !important;
    }
    .rate-limit-card {
      max-width: 520px;
      width: 100%;
      padding: 2.5rem;
      background: #fff !important;
      border-radius: 12px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
      text-align: center;
      border: 1px solid #e5e7eb;
    }
    .rate-limit-icon { color: #ea580c !important; }
    .rate-limit-title { color: #1f2937 !important; font-size: 1.5rem; margin: 0 0 0.75rem; }
    .rate-limit-message { color: #4b5563 !important; margin: 0 0 0.5rem; }
    .rate-limit-hint { color: #6b7280 !important; margin: 0 0 1.75rem; }
    .rate-limit-cta {
      display: inline-block;
      padding: 0.75rem 1.75rem;
      background: #000 !important;
      color: #fff !important;
      font-weight: 600;
      text-decoration: none;
      border-radius: 6px;
    }
  section(class="rate-limit-section")
    div(class="rate-limit-card")
      div(class="rate-limit-icon" aria-hidden="true")
        i(class="fa-solid fa-clock")
      h1(class="rate-limit-title") Please slow down
      p(class="rate-limit-message")= message
      p(class="rate-limit-hint") You've been making requests a bit too quickly. Please wait a few minutes before continuing—your limit will reset shortly.
      a(class="rate-limit-cta" href="/") Return to Home
