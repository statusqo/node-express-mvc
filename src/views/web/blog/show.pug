extends ../../layouts/main

block content
  article
    h1= post.title
    if post.publishedAt
      p(style="color: #888; font-size: 0.9rem;")= new Date(post.publishedAt).toLocaleDateString()
    if post.excerpt
      p(style="font-style: italic; color: #555;")= post.excerpt
    if post.body
      div(style="margin-top: 1rem; white-space: pre-wrap;")= post.body
  p
    a(href="/blog") &larr; Back to Blog
