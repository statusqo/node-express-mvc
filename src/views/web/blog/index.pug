extends ../../layouts/main

block content
  h1 Blog
  if posts && posts.length > 0
    ul(style="list-style: none; padding: 0;")
      each post in posts
        li(style="margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid #eee;")
          a(href="/blog/" + post.slug style="font-size: 1.25rem; font-weight: 600;")= post.title
          if post.excerpt
            p(style="margin: 0.5rem 0 0; color: #555;")= post.excerpt
          if post.publishedAt
            small(style="color: #888;")= new Date(post.publishedAt).toLocaleDateString()
  else
    p No posts yet. Check back later.
