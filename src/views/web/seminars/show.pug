extends ../../layouts/main

block append links
  link(rel="stylesheet" href="/public/css/contact.css")

block content
  article
    h1= product.title
    if product.description
      div(style="margin:1rem 0")= product.description
    if priceAmount != null
      p(style="font-size:1.125rem") Indicative price: #{Number(priceAmount).toFixed(2)} #{currency}
    p(style="margin-top:1rem; color:#555; font-size:0.95rem")
      | Seminars are arranged with our team to suit your schedule. Tell us you’re interested and we’ll get back to you.

    h2(style="font-size:1.15rem; margin-top:1.75rem") Request this seminar
    if inquiryOk
      p(style="color: green") Thanks! We’ve received your message and will be in touch.
    if inquiryFail
      p(style="color: red") Please check your details and try again.

    form(action="/seminars/inquiry" method="post")
      input(type="text" name="website" autocomplete="off" tabindex="-1" style="position:absolute;left:-9999px;")
      input(type="hidden" name="seminarSlug" value=product.slug)

      label(for="si-name") Name
      input#si-name(type="text" name="name" required)

      label(for="si-email") Email
      input#si-email(type="email" name="email" required)

      label(for="si-message") Message — preferred dates, group size, questions
      textarea#si-message(name="message" rows="6" required)

      button(type="submit") Send inquiry

  p(style="margin-top:1.5rem")
    a(href="/" + sectionPath) Back to seminars
