extends ../../layouts/main

block content
  h1 Order
  p Order ##{order.orderNumber}
  p Payment: #{order.paymentStatus} · Fulfillment: #{order.fulfillmentStatus}
  p Total: #{Number(order.total).toFixed(2)} #{order.currency}
  p Date: #{order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'}

  h2 Items
  ul(style="list-style:none; padding:0")
    each line in lines
      - const variant = line.ProductVariant || {}
      - const product = variant.Product || {}
      - const title = line.title || (product && product.title) || variant.title || ''
      li(style="padding:0.5rem 0")= title + " × " + (line.quantity || 1) + " @ " + Number(line.price).toFixed(2) + " = " + (Number(line.price) * (line.quantity || 1)).toFixed(2)

  if orderDiscount
    p(style="margin-top:0.5rem; color:#2a7a2a; font-size:0.95rem")
      | Discount applied&nbsp;
      strong= orderDiscount.code
      | &nbsp;(
      if orderDiscount.type === 'percentage'
        = Number(orderDiscount.value) + '% off'
      else
        = '€' + Number(orderDiscount.value).toFixed(2) + ' off'
      | )&nbsp;−€#{Number(orderDiscount.amountDeducted).toFixed(2)}

  if order.paymentStatus === "pending"
    p Your order is pending payment.
    p(style="margin-top:0.5rem;font-size:0.9rem;color:#666;max-width:28rem")
      | Payment is completed from the checkout or registration page using the card form. If you closed the browser before paying, place the order again from your cart or session page.
      |  If you believe you were charged but the order still shows pending, contact support and quote order number&nbsp;
      strong= '#' + order.orderNumber
      | .
  else if order.paymentStatus === "paid"
    p(style="color:#4caf50;font-weight:600") ✓ Payment successful!
    if order.sessionId && !order.userId && order.email
      p(style="margin-top:0.5rem") Register or log in with #{order.email} to access your order history.
      p(style="margin-top:0.5rem")
        a(href="/auth/register") Register
        |  ·
        a(href="/auth/login") Log in
    else
      p(style="margin-top:0.5rem") Thank you for your order.
  else if order.paymentStatus === "failed"
    p(style="color:#dc3545") Payment failed.
    p(style="margin-top:0.5rem;font-size:0.9rem;color:#666;max-width:28rem")
      | Start a new checkout from your cart or event registration page. If you need help with a failed charge, contact support with order number&nbsp;
      strong= '#' + order.orderNumber
      | .
  else if order.paymentStatus === "refunded"
    p(style="color:#666") This order has been refunded.

  if order.paymentStatus === "paid"
    if hasApprovedRefundRequest
      p(style="color:#666") This order has already been refunded.
    else if hasPendingRefundRequest
      p(style="color:#f0ad4e;font-weight:600") Refund requested — pending review.
    else if order.fulfillmentStatus === "delivered"
      form(action="/orders/" + order.id + "/refund-request" method="post" style="margin-top:0.5rem")
        label(for="refund-reason" style="display:block;margin-bottom:0.25rem") Reason (optional)
        textarea#refund-reason(name="reason" rows="2" style="width:100%;max-width:24rem;padding:0.5rem")
        button(type="submit" style="background:#6c757d;color:#fff;padding:0.5rem 1rem;border:none;border-radius:6px;cursor:pointer;margin-top:0.5rem") Request refund
    else
      p(style="color:#666") Refund can only be requested for delivered orders.

  if refundRequests && refundRequests.length
    h3(style="margin-top:1.5rem") Refund requests
    ul(style="list-style:none;padding:0")
      each r in refundRequests
        li(style="padding:0.5rem 0;border-bottom:1px solid #eee")
          | #{r.status} — #{r.createdAt ? new Date(r.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'}
          if r.reason
            |  — #{r.reason}
          if r.status === 'approved'
            |  — Full amount refunded

  p(style="margin-top:1.5rem")
    a(href="/orders") Back to orders
