extends ../../layouts/main

block content
  h1 My Orders
  if !orders || orders.length === 0
    p You have no orders yet.
    p
      a(href="/products") Browse products
  else
    ul(style="list-style:none; padding:0")
      each order in orders
        li(style="border:1px solid #ddd; padding:1rem; margin-bottom:0.5rem")
          a(href="/orders/" + order.id)
            strong Order ##{order.orderNumber}
          span(style="margin-left:1rem") Payment: #{order.paymentStatus || "—"}
          span(style="margin-left:1rem") Fulfillment: #{order.fulfillmentStatus ? (order.fulfillmentStatus.charAt(0).toUpperCase() + order.fulfillmentStatus.slice(1).replace(/_/g, " ")) : "—"}
          span(style="margin-left:1rem") Total: #{Number(order.total).toFixed(2)} #{order.currency}
          span(style="margin-left:1rem") #{order.createdAt ? new Date(order.createdAt).toLocaleDateString('en-GB', {day:'2-digit', month:'2-digit', year:'numeric'}) : '—'}
