extends ../../layouts/main

block content
  article
    h1= product.title
    if product.media && product.media.length
      div(style="margin:1rem 0; display:flex; flex-wrap:wrap; gap:0.75rem")
        each m in product.media
          - const isImage = m.mimeType && m.mimeType.startsWith('image/')
          if isImage
            img(src=m.url alt=m.alt || m.filename || product.title style="max-width:280px; max-height:210px; object-fit:contain; border-radius:6px; border:1px solid #eee")
          else
            a(href=m.url target="_blank" rel="noopener noreferrer" style="display:inline-flex; align-items:center; gap:0.5rem; padding:0.5rem 0.75rem; background:#f5f5f5; border-radius:6px; text-decoration:none; color:#333")
              span(style="font-size:0.9rem")= m.filename || m.path || 'File'
    if product.description
      div(style="margin:1rem 0")= product.description
    if (!variants || !variants.length) && price != null
      p(style="font-size:1.25rem") #{Number(price).toFixed(2)} #{DEFAULT_CURRENCY}
    if product.metaObjects && product.metaObjects.length
      div(style="margin:1rem 0")
        h3(style="font-size:1rem; margin-bottom:0.5rem") Meta Objects
        ul(style="list-style:none; padding:0; margin:0")
          each mo in product.metaObjects
            - const instanceValues = mo.ProductMetaObject && mo.ProductMetaObject.values && typeof mo.ProductMetaObject.values === 'object' ? mo.ProductMetaObject.values : {}
            - const definitionPairs = mo.definitionPairs || []
            - const typeByKey = Object.fromEntries(definitionPairs.map(p => [p.key, p.type || 'string']))
            li(style="padding:0.5rem 0; border-bottom:1px solid #eee")
              strong= mo.name
              if mo.type
                span(style="color:#666; margin-left:0.5rem") (#{mo.type})
              if Object.keys(instanceValues).length
                div(style="margin-top:0.5rem; margin-left:0; font-size:0.9rem")
                  each val, key in instanceValues
                    if val !== '' && val !== 'false'
                      - const attrType = typeByKey[key] || 'string'
                      - const displayVal = attrType === 'boolean' ? (val === 'true' ? 'Yes' : 'No') : (attrType === 'date' && val ? new Date(val).toLocaleDateString() : val)
                      div(style="margin:0.25rem 0")
                        span(style="font-weight:500; color:#555")= key + ': '
                        if attrType === 'url' && val
                          a(href=val target="_blank" rel="noopener noreferrer")= val
                        else
                          span= displayVal
    if variants && variants.length
      div(style="margin-top:1.5rem")
        h2(style="font-size:1.1rem; margin-bottom:0.75rem") Options
        ul(style="list-style:none; padding:0; margin:0; display:flex; flex-direction:column; gap:0.5rem")
          each v in variants
            li(style="display:flex; align-items:center; gap:1rem; padding:0.75rem; border:1px solid #ddd; border-radius:6px")
              span(style="font-weight:500; flex:1")= product.title + ' - ' + v.title
              span(style="color:#555; min-width:6rem; text-align:right")= Number(v.priceAmount).toFixed(2) + ' ' + currency
              if v.quantity > 0
                form.js-add-to-cart-form(action="/cart/add" method="post")
                  input(type="hidden" name="productVariantId" value=v.id)
                  input(type="hidden" name="quantity" value="1")
                  button(type="submit") Add to cart
              else
                span(style="color:#999; font-size:0.9rem") Sold out
    else if defaultVariantId
      if defaultVariantQuantity > 0
        form.js-add-to-cart-form(action="/cart/add" method="post" style="margin-top:1rem")
          input(type="hidden" name="productVariantId" value=defaultVariantId)
          input(type="hidden" name="quantity" value="1")
          button(type="submit") Add to cart
      else
        p(style="color:#999; margin-top:1rem") Sold out
  a(href="/products") Back to products
