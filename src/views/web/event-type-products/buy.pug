extends ../../layouts/main

block content
  article
    h1 Book: #{product.title}
    if product.description
      p(style="margin:0.5rem 0")= product.description
    - const variant = product.ProductVariants && product.ProductVariants[0]
    - const priceRow = variant && variant.ProductPrices && variant.ProductPrices[0]
    - const priceAmount = priceRow ? Number(priceRow.amount) : null
    - const currency = priceRow ? priceRow.currency : 'USD'
    if priceAmount != null
      p(style="font-size:1.125rem") #{Number(priceAmount).toFixed(2)} #{currency} per session

    form(method="post" action="/" + sectionPath + "/" + product.slug + "/buy")
      h2(style="font-size:1.1rem; margin-top:1rem") Choose a session
      ul(style="list-style:none; padding:0; margin:0")
        each ev in events
          li(style="margin-bottom:0.5rem")
            label(style="display:flex; align-items:center; gap:0.5rem; cursor:pointer")
              input(type="radio" name="eventId" value=ev.id required)
              span= ev.startDate ? ev.startDate : '—'
              if ev.startTime
                span= String(ev.startTime).substring(0, 5)
              if ev.location
                span(style="color:#666")= ev.location

      h2(style="font-size:1.1rem; margin-top:1.25rem") Your details
      div(style="margin-bottom:0.75rem")
        label(for="email") Email *
        input#email(type="email" name="email" required value=user && user.email ? user.email : "" style="display:block; width:100%; max-width:20rem; margin-top:0.25rem")
      div(style="margin-bottom:0.75rem")
        label(for="forename") First name
        input#forename(type="text" name="forename" value=user && user.username ? user.username : "" style="display:block; width:100%; max-width:20rem; margin-top:0.25rem")
      div(style="margin-bottom:0.75rem")
        label(for="surname") Last name
        input#surname(type="text" name="surname" style="display:block; width:100%; max-width:20rem; margin-top:0.25rem")

      p(style="margin-top:1rem")
        button(type="submit" style="background:#635bff; color:#fff; padding:0.75rem 1.5rem; border:none; border-radius:6px; font-weight:600; cursor:pointer") Continue to payment

  a(href="/" + sectionPath + "/" + product.slug style="display:inline-block; margin-top:1rem") Back to #{product.title}
