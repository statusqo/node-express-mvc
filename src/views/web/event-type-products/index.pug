extends ../../layouts/main

block content
  h1= typeLabel
  if products && products.length
    ul(style="list-style:none; padding:0")
      each product in products
        li(style="border:1px solid #ddd; padding:1rem; margin-bottom:0.5rem")
          strong= product.title
          if product.description
            p(style="margin:0.5rem 0")= product.description
          if product.priceAmount != null
            span #{Number(product.priceAmount).toFixed(2)} #{DEFAULT_CURRENCY}
          a(href="/" + sectionPath + "/" + product.slug style="margin-left:0.5rem") View details
  else
    p No #{typeLabel.toLowerCase()} available at the moment.
