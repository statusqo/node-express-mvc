NODE_ENV=development
PORT=8080
BASE_URL=http://localhost:8080

# Database — defaults to SQLite file storage.
# Set DB_STORAGE=:memory: for a fully in-memory database: auto-migrates and
# auto-seeds on every boot, data is lost on restart. Useful for local testing.
DB_DIALECT=sqlite
DB_STORAGE=database.sqlite

# Auth: use a long random secret in production (e.g. openssl rand -base64 32)
SESSION_SECRET=change_me_in_production

# Google OAuth (optional; leave empty to disable "Sign in with Google")
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

# Email / SMTP
# Pre-filled for Gmail. Requires a Google App Password (not your regular password).
# Enable 2-Step Verification on your Google account, then generate an App Password at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
# "From" address shown in outgoing emails
MAIL_FROM=your-gmail@gmail.com
# Admin recipient for contact-form messages
MAIL_TO=your-gmail@gmail.com

# Payment gateway (default: stripe)
PAYMENT_DEFAULT_GATEWAY=stripe

# Stripe (required when using Stripe as payment gateway)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Zoom (optional; for online events / webinars). Leave empty to disable.
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
# Optional; defaults to BASE_URL + /admin/zoom/callback
# ZOOM_REDIRECT_URI=http://localhost:3000/admin/zoom/callback
# Required for Zoom webhook URL verification (Marketplace). When a meeting is deleted in Zoom,
# the app receives meeting.deleted and marks the event as orphaned so you can Re-sync or Cancel.
# Copy from Zoom Marketplace app > Feature > Event Subscriptions > Secret Token.
ZOOM_WEBHOOK_SECRET=
# Optional: AES-256 key for encrypting Zoom OAuth tokens at rest (base64-encoded 32 bytes).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ZOOM_TOKEN_ENCRYPTION_KEY=
# Optional: session cookie domain override (production only).
# Leave empty to restrict the cookie to the current host (recommended for single-domain apps).
# SESSION_COOKIE_DOMAIN=example.com

# Company / issuer info — printed on every invoice
COMPANY_NAME=My Company d.o.o.
COMPANY_ADDRESS_LINE1=Ulica Primjera 12
COMPANY_ADDRESS_LINE2=10000 Zagreb
COMPANY_OIB=12345678901
# VAT ID (PDV ID) shown on R1 invoices — typically HR + OIB
COMPANY_VAT_ID=HR12345678901

# Croatian fiscalisation (Zakon o fiskalizaciji)
# Leave FINA_CERT_PATH empty to disable fiscalisation entirely (invoices will be issued without ZKI/JIR).
# FINA_ENVIRONMENT accepts "demo" (cistest.apis-it.hr) or "production" (cis.porezna-uprava.hr).
FINA_ENVIRONMENT=demo
FINA_CERT_PATH=
FINA_CERT_PASSWORD=
FINA_OPERATOR_OIB=
FINA_BUSINESS_PREMISES_ID=WEB
FINA_DEVICE_ID=1
# P = poslovni prostor (premises-based sequence) — correct for most setups
FINA_SEQUENCE_LABEL=P
# Whether the company is in the Croatian VAT (PDV) system
COMPANY_IN_VAT_SYSTEM=true
# FINA SOAP request timeout in milliseconds (default 10s)
# FINA_TIMEOUT_MS=10000